@model Busticket.Models.Ruta
@{
    Layout = "_Layout";
}
<!-- HEADER -->
<header class="absolute top-0 inset-x-0 z-50">
    <div class="max-w-7xl mx-auto px-10 py-6
                    flex items-center justify-between
                    text-black">

        <!-- NAV -->
        <!-- LOGO -->
        <a href="/Home/Index"
           class="text-2xl tracking-widest uppercase font-semibold">
            Busticket
        </a>

        <!-- USER ACTIONS -->
        <div class="flex gap-10 text-sm tracking-widest uppercase items-center">
            <a href="/Ayuda"
               class="relative uppercase tracking-widest text-sm
          after:content-[''] after:absolute after:left-0 after:-bottom-1
          after:w-0 after:h-[1px] after:bg-white
          after:transition-all after:duration-300
          hover:after:w-full">
                Ayuda
            </a>


            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a href="/Perfil"
                   title="Mi cuenta"
                   class="flex items-center justify-center w-10 h-10
                                          rounded-full border border-white
                                          hover:bg-white hover:text-black transition">
                    👤
                </a>

                <form asp-controller="Auth"
                      asp-action="Logout"
                      method="post"
                      class="inline">
                    <button type="submit"
                            class="relative uppercase tracking-widest text-sm
                           after:content-[''] after:absolute after:left-0 after:-bottom-1
                           after:w-0 after:h-[1px] after:bg-white
                           after:transition-all after:duration-300
                           hover:after:w-full">
                        Cerrar sesión
                    </button>

                </form>
            }
            else
            {
                <a href="/Auth/Login"
                   class="relative uppercase tracking-widest text-sm
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-white
                      after:transition-all after:duration-300
                      hover:after:w-full">
                    Iniciar sesión
                </a>

            }
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Index"
                   class="relative uppercase tracking-widest text-sm
                          after:content-[''] after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-white
                          after:transition-all after:duration-300
                          hover:after:w-full">
                    Admin
                </a>
            }
            @if (User.IsInRole("Empresa"))
            {
                <a href="/Empresa/Dashboard"
                   class="relative uppercase tracking-widest text-sm
                          after:content-[''] after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-white
                          after:transition-all after:duration-300
                          hover:after:w-full">
                    Empresa
                </a>
            }


        </div>
    </div>
</header>
<div class="max-w-3xl mx-auto mt-10 bg-white p-6 rounded-xl shadow-md">
    <h1 class="text-3xl font-bold mb-6">Editar Ruta</h1>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="text-red-600 mb-2">@TempData["ErrorMessage"]</div>
    }

    <form asp-controller="Admin" asp-action="EditarRuta" method="post" class="space-y-4">
        <input type="hidden" asp-for="RutaId" />

        <!-- Ciudad Origen -->
        <div>
            <label>Ciudad Origen</label>
            <select asp-for="CiudadOrigenId" class="w-full border border-gray-300 rounded-lg px-3 py-2"
                    asp-items="@(new SelectList(ViewBag.Ciudades ?? new List<Busticket.Models.Ciudad>(), "CiudadId", "Nombre", Model?.CiudadOrigenId))">
                <option value="0">-- Seleccione Ciudad --</option>
            </select>
            <span asp-validation-for="CiudadOrigenId" class="text-red-600"></span>
        </div>

        <!-- Ciudad Destino -->
        <div>
            <label>Ciudad Destino</label>
            <select asp-for="CiudadDestinoId" class="w-full border border-gray-300 rounded-lg px-3 py-2"
                    asp-items="@(new SelectList(ViewBag.Ciudades ?? new List<Busticket.Models.Ciudad>(), "CiudadId", "Nombre", Model?.CiudadDestinoId))">
                <option value="0">-- Seleccione Ciudad --</option>
            </select>
            <span asp-validation-for="CiudadDestinoId" class="text-red-600"></span>
        </div>

        <!-- Empresa -->
        <div>
            <label>Empresa</label>
            <select asp-for="EmpresaId" class="w-full border border-gray-300 rounded-lg px-3 py-2"
                    asp-items="@(new SelectList(ViewBag.Empresas ?? new List<Busticket.Models.Empresa>(), "EmpresaId", "Nombre", Model?.EmpresaId))">
                <option value="0">-- Seleccione Empresa --</option>
            </select>
            <span asp-validation-for="EmpresaId" class="text-red-600"></span>
        </div>

        <!-- Precio -->
        <div>
            <label>Precio</label>
            <input asp-for="Precio" type="number" step="0.01" min="0.01" class="w-full border border-gray-300 rounded px-3 py-2" />
            <span asp-validation-for="Precio" class="text-red-600"></span>
        </div>

        <!-- Duración -->
        <div>
            <label>Duración (min)</label>
            <input asp-for="DuracionMin" type="number" min="1" class="w-full border border-gray-300 rounded px-3 py-2" />
            <span asp-validation-for="DuracionMin" class="text-red-600"></span>
        </div>

        <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg">Actualizar</button>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const success = '@TempData["SuccessMessage"]';
            const error = '@TempData["ErrorMessage"]';
            if (success) Swal.fire('Éxito', success, 'success');
            if (error) Swal.fire('Error', error, 'error');
        });
    </script>
}
