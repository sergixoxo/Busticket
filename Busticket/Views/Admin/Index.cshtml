@model List<Busticket.Models.ViewModels.ReporteVentaVM1>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Panel Administrativo</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <!-- HEADER -->
    <header class="absolute top-0 inset-x-0 z-50">
        <div class="max-w-7xl mx-auto px-10 py-6
                    flex items-center justify-between
                    text-black">

            <!-- NAV -->
            <!-- LOGO -->
            <a href="/Home/Index"
               class="text-2xl tracking-widest uppercase font-semibold">
                Busticket
            </a>

            <!-- USER ACTIONS -->
            <div class="flex gap-10 text-sm tracking-widest uppercase items-center">
                <a href="/Ayuda"
                   class="relative uppercase tracking-widest text-sm
          after:content-[''] after:absolute after:left-0 after:-bottom-1
          after:w-0 after:h-[1px] after:bg-white
          after:transition-all after:duration-300
          hover:after:w-full">
                    Ayuda
                </a>


                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/Perfil"
                       title="Mi cuenta"
                       class="flex items-center justify-center w-10 h-10
                                          rounded-full border border-white
                                          hover:bg-white hover:text-black transition">
                        👤
                    </a>

                    <form asp-controller="Auth"
                          asp-action="Logout"
                          method="post"
                          class="inline">
                        <button type="submit"
                                class="relative uppercase tracking-widest text-sm
                           after:content-[''] after:absolute after:left-0 after:-bottom-1
                           after:w-0 after:h-[1px] after:bg-white
                           after:transition-all after:duration-300
                           hover:after:w-full">
                            Cerrar sesión
                        </button>

                    </form>
                }
                else
                {
                    <a href="/Auth/Login"
                       class="relative uppercase tracking-widest text-sm
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-white
                      after:transition-all after:duration-300
                      hover:after:w-full">
                        Iniciar sesión
                    </a>

                }
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index"
                       class="relative uppercase tracking-widest text-sm
                          after:content-[''] after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-white
                          after:transition-all after:duration-300
                          hover:after:w-full">
                        Admin
                    </a>
                }
                @if (User.IsInRole("Empresa"))
                {
                    <a href="/Empresa/Dashboard"
                       class="relative uppercase tracking-widest text-sm
                          after:content-[''] after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-white
                          after:transition-all after:duration-300
                          hover:after:w-full">
                        Empresa
                    </a>
                }


            </div>
        </div>
    </header>

    <!-- CONTENIDO -->
    <div class="max-w-5xl mx-auto mt-14 px-4">

        <h1 class="text-4xl font-bold text-gray-800 mb-10 text-center">
            Panel Administrativo
        </h1>

        <!-- BOTONES -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-12">
            <a asp-controller="Admin" asp-action="Rutas"
               class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-4 rounded-xl shadow-md text-center font-semibold transition">
                Ver Rutas
            </a>

            <a asp-controller="Empresa" asp-action="Index"
               class="bg-green-600 hover:bg-green-700 text-white px-6 py-4 rounded-xl shadow-md text-center font-semibold transition">
                Ver Empresa
            </a>
        </div>

        <!-- FILTROS + EXCEL -->
        <div class="bg-white p-5 rounded-xl shadow mb-6 flex flex-wrap gap-4 items-end">

            <div>
                <label class="block text-sm font-semibold text-gray-600">Desde</label>
                <input type="date" id="fechaInicio"
                       class="border rounded px-3 py-2 text-sm">
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-600">Hasta</label>
                <input type="date" id="fechaFin"
                       class="border rounded px-3 py-2 text-sm">
            </div>

            <button type="button"
                    onclick="filtrarTabla()"
                    class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition">
                Filtrar
            </button>

            <button type="button"
                    onclick="exportarExcel()"
                    class="ml-auto bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition">
                 Descargar Excel
            </button>
        </div>

        <!-- TABLA -->
        <div class="overflow-x-auto">
            <table id="tablaVentas"
                   class="w-full bg-white shadow-md rounded-lg overflow-hidden">

                <thead class="bg-gray-200 text-gray-700">
                    <tr>
                        <th class="px-4 py-2 text-left">Venta ID</th>
                        <th class="px-4 py-2 text-left">Usuario</th>
                        <th class="px-4 py-2 text-left">Empresa</th>
                        <th class="px-4 py-2 text-left">Precio</th>
                        <th class="px-4 py-2 text-left">Fecha</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-b hover:bg-gray-50 transition"
                            data-fecha="@item.Fecha.ToString("yyyy-MM-dd")">

                            <td class="px-4 py-2">@item.VentaId</td>
                            <td class="px-4 py-2">@item.Usuario</td>
                            <td class="px-4 py-2">@item.Empresa</td>
                            <td class="px-4 py-2 font-semibold text-green-600">
                                $@item.Precio.ToString("N0")
                            </td>
                            <td class="px-4 py-2">@item.Fecha.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>


            </table>
        </div>

    </div>  

   <script src="~/js/admin.js"></script>

</body>
</html>
