@model List<Busticket.Models.Ruta>

@{
    Layout = "_Layout";
}
<!-- HEADER -->
<header class="absolute top-0 inset-x-0 z-50">
    <div class="max-w-7xl mx-auto px-10 py-6
                    flex items-center justify-between
                    text-black">

        <!-- NAV -->
        <!-- LOGO -->
        <a href="/Home/Index"
           class="text-2xl tracking-widest uppercase font-semibold">
            Busticket
        </a>

        <!-- USER ACTIONS -->
        <div class="flex gap-10 text-sm tracking-widest uppercase items-center">
            <a href="/Ayuda"
               class="relative uppercase tracking-widest text-sm
          after:content-[''] after:absolute after:left-0 after:-bottom-1
          after:w-0 after:h-[1px] after:bg-white
          after:transition-all after:duration-300
          hover:after:w-full">
                Ayuda
            </a>


            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a href="/Perfil"
                   title="Mi cuenta"
                   class="flex items-center justify-center w-10 h-10
                                          rounded-full border border-white
                                          hover:bg-white hover:text-black transition">
                    👤
                </a>

                <form asp-controller="Auth"
                      asp-action="Logout"
                      method="post"
                      class="inline">
                    <button type="submit"
                            class="relative uppercase tracking-widest text-sm
                           after:content-[''] after:absolute after:left-0 after:-bottom-1
                           after:w-0 after:h-[1px] after:bg-white
                           after:transition-all after:duration-300
                           hover:after:w-full">
                        Cerrar sesión
                    </button>

                </form>
            }
            else
            {
                <a href="/Auth/Login"
                   class="relative uppercase tracking-widest text-sm
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-white
                      after:transition-all after:duration-300
                      hover:after:w-full">
                    Iniciar sesión
                </a>

            }
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Index"
                   class="relative uppercase tracking-widest text-sm
                          after:content-[''] after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-white
                          after:transition-all after:duration-300
                          hover:after:w-full">
                    Admin
                </a>
            }
            @if (User.IsInRole("Empresa"))
            {
                <a href="/Empresa/Dashboard"
                   class="relative uppercase tracking-widest text-sm
                          after:content-[''] after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-white
                          after:transition-all after:duration-300
                          hover:after:w-full">
                    Empresa
                </a>
            }


        </div>
    </div>
</header>
<div class="max-w-6xl mx-auto mt-10">
    <h1 class="text-3xl font-bold mb-6">Listado de Rutas</h1>

    <div class="flex justify-end mb-4">
        <a asp-action="CrearRuta"
           class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg shadow-md transition">
            + Crear Ruta
        </a>
    </div>

    <div class="overflow-hidden rounded-xl shadow-lg border border-gray-200">
        <table class="w-full text-left border-collapse">
            <thead class="bg-gray-100 text-gray-700 uppercase text-sm">
                <tr>
                    <th class="p-4">Origen</th>
                    <th class="p-4">Destino</th>
                    <th class="p-4">Precio</th>
                    <th class="p-4">Empresa</th>
                    <th class="p-4 text-center">Acciones</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-200 bg-white">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition">
                        <td class="p-4 font-medium">@item.CiudadOrigen.Nombre</td>
                        <td class="p-4">@item.CiudadDestino.Nombre</td>

                        <td class="p-4">$@item.Precio</td>
                        <td class="p-4">@item.Empresa?.Nombre</td>

                        <td class="p-4 text-center flex items-center justify-center gap-4">
                            <a asp-action="EditarRuta" asp-route-id="@item.RutaId"
                               class="text-yellow-600 hover:text-yellow-700 font-medium">Editar</a>

                            <a asp-action="EliminarRuta" asp-route-id="@item.RutaId"
                               class="text-red-600 hover:text-red-700 font-medium">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
