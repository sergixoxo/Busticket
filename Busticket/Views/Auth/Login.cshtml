@model Busticket.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Busticket | Iniciar sesión</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .animate-fadeUp {
            animation: fadeUp 0.7s ease-out forwards;
        }

        .animate-fadeIn {
            animation: fadeIn 0.6s ease-out forwards;
        }
    </style>
</head>

<body class="min-h-screen bg-gradient-to-br from-gray-100 via-gray-50 to-blue-50 flex items-center justify-center">

    <!-- CONTENEDOR PRINCIPAL -->
    <div class="flex w-full max-w-6xl min-h-[650px] bg-white rounded-3xl
                shadow-[0_20px_60px_rgba(0,0,0,0.12)]
                overflow-hidden animate-fadeUp">

        <!-- FORM -->
        <div class="flex flex-col justify-center px-16 py-12 w-1/2">

            <h1 class="text-2xl font-bold tracking-tight text-blue-700 mb-10">
                Busticket
            </h1>

            <h2 class="text-4xl font-bold text-gray-900 mb-3">
                Bienvenido de nuevo
            </h2>

            <p class="text-gray-600 mb-10">
                Accede a tu cuenta y gestiona tus viajes fácilmente.
            </p>

            <form asp-action="Login" method="post" class="space-y-6 animate-fadeIn">

                <!-- EMAIL -->
                <div>
                    <label class="font-medium text-gray-700">
                        Correo electrónico
                    </label>
                    <input asp-for="Email"
                           class="w-full border border-gray-300 rounded-xl p-3 mt-1
                                  transition-all duration-200
                                  focus:outline-none focus:ring-2 focus:ring-blue-600
                                  focus:scale-[1.01]"
                           placeholder="Ingresa tu correo" />
                    <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                </div>

                <!-- PASSWORD -->
                <div>
                    <label class="font-medium text-gray-700">
                        Contraseña
                    </label>

                    <div class="relative">
                        <input asp-for="Password"
                               id="passwordInput"
                               type="password"
                               class="w-full border border-gray-300 rounded-xl p-3 mt-1 pr-12
                                      transition-all duration-200
                                      focus:outline-none focus:ring-2 focus:ring-blue-600
                                      focus:scale-[1.01]"
                               placeholder="Ingresa tu contraseña" />

                        <button type="button"
                                onclick="togglePassword()"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-800">
                            👁️
                        </button>
                    </div>

                    <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
                </div>

                @if (ViewBag.Error != null)
                {
                    <p class="text-red-500 text-sm animate-fadeIn">
                        @ViewBag.Error
                    </p>
                }

                <a href="/Cuenta/OlvidarPassword"
                   class="text-sm text-blue-600 hover:underline">
                    ¿Olvidaste tu contraseña?
                </a>

                <!-- BOTÓN LOGIN -->
                <button type="submit"
                        class="w-full bg-gradient-to-r from-blue-600 to-indigo-600
                               text-white py-3 rounded-xl font-semibold
                               transition-all duration-300
                               hover:scale-[1.02] hover:shadow-xl
                               active:scale-95">
                    Iniciar sesión
                </button>

                <!-- SOCIAL LOGIN -->
                <div class="flex gap-3 pt-4">

                    <button type="button"
                            class="flex-1 border border-gray-300 py-3 rounded-xl
                                   flex items-center justify-center gap-2
                                   transition-all duration-300
                                   hover:bg-gray-50 hover:scale-[1.02]
                                   active:scale-95">
                        <img src="https://res.cloudinary.com/dbt58u6ag/image/upload/v1767317075/google_tbrvoc.png"
                             class="w-5 h-5" />
                        Google
                    </button>

                    <button type="button"
                            class="flex-1 border border-gray-300 py-3 rounded-xl
                                   flex items-center justify-center gap-2
                                   transition-all duration-300
                                   hover:bg-gray-50 hover:scale-[1.02]
                                   active:scale-95">
                        <img src="https://res.cloudinary.com/dbt58u6ag/image/upload/v1767317115/apple_hvlkqx.png"
                             class="w-5 h-5" />
                        Apple
                    </button>
                </div>

                <p class="text-sm text-gray-600 mt-6 text-center">
                    ¿No tienes cuenta?
                    <a href="/Auth/Register"
                       class="text-blue-600 font-semibold hover:underline">
                        Regístrate
                    </a>
                </p>

            </form>
        </div>

        <!-- IMAGEN -->
        <div class="w-1/2 overflow-hidden">
            <img src="https://res.cloudinary.com/dbt58u6ag/image/upload/v1764884373/chris-lee-70l1tDAI6rM-unsplash_2_b4fmff.png"
                 class="w-full h-full object-cover
                        transition-transform duration-[1200ms]
                        hover:scale-105"
                 alt="Imagen de ruta" />
        </div>

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            input.type = input.type === "password" ? "text" : "password";
        }
    </script>

</body>
</html>
