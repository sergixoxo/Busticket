@{
    Layout = null;
    
}
<partial name="_DarkModeScript" />
<script src="https://cdn.tailwindcss.com"></script>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="~/css/ModeDark.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f4f6f8;
        }

        .container {
            max-width: 1000px;
            margin: 60px auto;
            padding: 0 20px;
        }

        .title {
            font-size: 32px;
            font-weight: 700;
            color: #1d3557;
            margin-bottom: 30px;
        }

        .card {
            background: #fff;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 6px 16px rgba(0,0,0,.06);
        }

            .card h3 {
                font-size: 18px;
                margin-bottom: 10px;
                color: #1d3557;
            }

            .card p {
                color: #555;
                line-height: 1.6;
            }

        .contact {
            background: #1d3557;
            color: #fff;
            border-radius: 12px;
            padding: 25px;
            margin-top: 30px;
        }

            .contact h3 {
                margin-bottom: 10px;
            }

            .contact p {
                opacity: .9;
            }

        .btn {
            display: inline-block;
            margin-top: 15px;
            background: #fff;
            color: #1d3557;
            padding: 12px 18px;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: .2s;
        }

            .btn:hover {
                background: #e6e6e6;
            }
    </style>
</head>

<body>
    <!-- HEADER -->
    <header class="absolute top-0 inset-x-0 z-50">
        <div class="max-w-7xl mx-auto px-10 py-6
                flex items-center justify-between
                text-black">

            <!-- IZQUIERDA -->
            <div class="flex items-center gap-6">

                <!-- BOTÓN VOLVER -->
                @if (Context.Request.Path != "/Home/Index")
                {
                    <button onclick="history.back()"
                            class="flex items-center gap-2 text-sm tracking-widest uppercase
                                   opacity-80 hover:opacity-100 transition group">

                        <!-- ICONO FLECHA SVG -->
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-5 h-5 transform group-hover:-translate-x-1 transition duration-300"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M15 19l-7-7 7-7" />
                        </svg>

                        Volver
                    </button>
                }

                <!-- LOGO -->
                <a href="/Home/Index"
                   class="text-2xl tracking-widest uppercase font-semibold">
                    Busticket
                </a>

            </div>

            <!-- DERECHA -->
            <div class="flex gap-10 text-sm tracking-widest uppercase items-center">

                <!-- AYUDA -->
                <a href="/Ayuda"
                   class="relative
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-black
                      after:transition-all after:duration-300
                      hover:after:w-full">
                    Ayuda
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <!-- PERFIL -->
                    <a href="/Perfil"
                       title="Mi cuenta"
                       class="flex items-center justify-center w-10 h-10
                              rounded-full border border-black
                              hover:bg-black hover:text-white transition">
                        👤
                    </a>

                    <!-- LOGOUT -->
                    <form asp-controller="Auth"
                          asp-action="Logout"
                          method="post"
                          class="inline">
                        <button type="submit"
                                class="relative
                                       after:content-[''] after:absolute after:left-0 after:-bottom-1
                                       after:w-0 after:h-[1px] after:bg-black
                                       after:transition-all after:duration-300
                                       hover:after:w-full">
                            Cerrar sesión
                        </button>
                    </form>
                }
                else
                {
                    <!-- LOGIN -->
                    <a href="/Auth/Login"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Iniciar sesión
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Admin
                    </a>
                }

                @if (User.IsInRole("Empresa"))
                {
                    <a href="/Empresa/Dashboard"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Empresa
                    </a>
                }

            </div>
        </div>
    </header>
    <div class="container">
        <div class="title">Centro de Ayuda</div>

        <div class="card">
            <h3>📌 ¿Cómo comprar un boleto?</h3>
            <p>
                Selecciona tu ruta, fecha de viaje y asiento disponible.
                Luego completa el pago y recibirás tu boleto en tu cuenta.
            </p>
        </div>

        <div class="card">
            <h3>👤 Problemas con tu cuenta</h3>
            <p>
                Si olvidaste tu contraseña, puedes recuperarla desde la opción
                <strong>“¿Olvidaste tu contraseña?”</strong> en el inicio de sesión.
            </p>
        </div>

        <div class="card">
            <h3>🚌 Gestión de viajes</h3>
            <p>
                Desde tu perfil puedes ver tus próximos viajes,
                el historial y los detalles de cada boleto comprado.
            </p>
        </div>

        <div class="card">
            <h3>💳 Pagos y facturación</h3>
            <p>
                Aceptamos múltiples métodos de pago.
                Si tu pago fue rechazado, verifica con tu entidad bancaria.
            </p>
        </div>

        <div class="contact">
            <h3>📞 ¿Necesitas más ayuda?</h3>
            <p>
                Escríbenos y nuestro equipo de soporte te ayudará lo antes posible.
            </p>

            <a href="https://wa.me/573196328638?text=Hola%20necesito%20ayuda%20con%20Busticket" target="_blank" class="btn">
                Contactar soporte por WhatsApp
            </a>
        </div>
    </div>

</body>
</html>