@model Busticket.Models.Empresa

@{
    Layout = "_Layout";
}

<!-- HEADER -->
<header class="absolute top-0 inset-x-0 z-50">
    <div class="max-w-7xl mx-auto px-10 py-6
                flex items-center justify-between
                text-black">

        <!-- IZQUIERDA -->
        <div class="flex items-center gap-6">

            @if (Context.Request.Path != "/Home/Index")
            {
                <button onclick="history.back()"
                        class="flex items-center gap-2 text-sm tracking-widest uppercase
                                   opacity-80 hover:opacity-100 transition group">

                    <svg xmlns="http://www.w3.org/2000/svg"
                         class="w-5 h-5 transform group-hover:-translate-x-1 transition duration-300"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 19l-7-7 7-7" />
                    </svg>

                    Volver
                </button>
            }

            <a href="/Home/Index"
               class="text-2xl tracking-widest uppercase font-semibold">
                Busticket
            </a>
        </div>

        <!-- DERECHA -->
        <div class="flex gap-10 text-sm tracking-widest uppercase items-center">

            <a href="/Ayuda"
               class="relative after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-black
                      after:transition-all after:duration-300
                      hover:after:w-full">
                Ayuda
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a href="/Perfil"
                   class="flex items-center justify-center w-10 h-10
                              rounded-full border border-black
                              hover:bg-black hover:text-white transition">
                    👤
                </a>

                <form asp-controller="Auth" asp-action="Logout" method="post">
                    <button type="submit"
                            class="relative after:absolute after:left-0 after:-bottom-1
                                       after:w-0 after:h-[1px] after:bg-black
                                       after:transition-all after:duration-300
                                       hover:after:w-full">
                        Cerrar sesión
                    </button>
                </form>
            }
        </div>
    </div>
</header>

<!-- FORM -->
<div class="max-w-3xl mx-auto mt-20 bg-white p-8 rounded-2xl shadow-lg">
    <h1 class="text-3xl font-bold mb-6">Crear Empresa</h1>

    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-red-600 mb-4"></div>

        <!-- NOMBRE -->
        <div class="mb-4">
            <label class="block text-sm font-semibold mb-1">Nombre</label>
            <input asp-for="Nombre"
                   class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-black" />
        </div>

        <!-- NIT -->
        <div class="mb-4">
            <label class="block text-sm font-semibold mb-1">NIT</label>
            <input asp-for="Nit"
                   class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-black" />
        </div>

        <!-- EMAIL -->
        <div class="mb-4">
            <label class="block text-sm font-semibold mb-1">Email</label>
            <input asp-for="Email" type="email"
                   class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-black" />
        </div>

        <!-- PAIS -->
        <div class="mb-4">
            <label class="block text-sm font-semibold mb-1">País</label>
            <input asp-for="Pais"
                   class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-black" />
        </div>

        <!-- TELEFONO -->
        <div class="mb-6">
            <label class="block text-sm font-semibold mb-1">Teléfono</label>
            <input asp-for="Telefono"
                   class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-black" />
        </div>

        <!-- BOTÓN -->
        <button type="submit"
                class="w-full bg-black text-white py-3 rounded-lg
                       hover:bg-gray-800 transition font-semibold">
            Crear Empresa
        </button>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}