@model Busticket.Models.Ruta
@{
    Layout = "_Layout";
}

<div class="max-w-3xl mx-auto mt-10 bg-white p-6 rounded-xl shadow-md">
    <h1 class="text-3xl font-bold mb-6">Crear Nueva Ruta</h1>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="text-red-600 mb-2">
            @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="CrearRuta" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-danger"></div>

        <label>Ciudad Origen</label>
        <select asp-for="CiudadOrigenId"
                asp-items="@(new SelectList(ViewBag.Ciudades, "CiudadId", "Nombre"))">
            <option value="">Seleccione</option>
        </select>

        <label>Ciudad Destino</label>
        <select asp-for="CiudadDestinoId"
                asp-items="@(new SelectList(ViewBag.Ciudades, "CiudadId", "Nombre"))">
            <option value="">Seleccione</option>
        </select>

        <label>Precio</label>
        <input asp-for="Precio" type="number" step="0.01" />

        <label>Duración (min)</label>
        <input asp-for="DuracionMin" type="number" />

        <label>Fecha Salida</label>
        <input asp-for="FechaSalida" type="datetime-local" />

        <label>Fecha Llegada</label>
        <input asp-for="FechaLlegada" type="datetime-local" />

        <button type="submit">Crear Ruta</button>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const success = '@TempData["SuccessMessage"]';
            const error = '@TempData["ErrorMessage"]';

            if (success) {
                Swal.fire("Éxito", success, "success");
            }

            if (error) {
                Swal.fire("Error", error, "error");
            }
        });
    </script>
}
