@model Busticket.Models.Ruta
@{
    Layout = "_Layout";
}

<script src="https://cdn.tailwindcss.com"></script>
<!-- HEADER -->
<header class="absolute top-0 inset-x-0 z-50">
    <div class="max-w-7xl mx-auto px-10 py-6
                flex items-center justify-between
                text-black">

        <!-- IZQUIERDA -->
        <div class="flex items-center gap-6">

            <!-- BOTÓN VOLVER -->
            @if (Context.Request.Path != "/Home/Index")
            {
                <button onclick="history.back()"
                        class="flex items-center gap-2 text-sm tracking-widest uppercase
                                   opacity-80 hover:opacity-100 transition group">

                    <!-- ICONO FLECHA SVG -->
                    <svg xmlns="http://www.w3.org/2000/svg"
                         class="w-5 h-5 transform group-hover:-translate-x-1 transition duration-300"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 19l-7-7 7-7" />
                    </svg>

                    Volver
                </button>
            }

            <!-- LOGO -->
            <a href="/Home/Index"
               class="text-2xl tracking-widest uppercase font-semibold">
                Busticket
            </a>

        </div>

        <!-- DERECHA -->
        <div class="flex gap-10 text-sm tracking-widest uppercase items-center">

            <!-- AYUDA -->
            <a href="/Ayuda"
               class="relative
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-black
                      after:transition-all after:duration-300
                      hover:after:w-full">
                Ayuda
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <!-- PERFIL -->
                <a href="/Perfil"
                   title="Mi cuenta"
                   class="flex items-center justify-center w-10 h-10
                              rounded-full border border-black
                              hover:bg-black hover:text-white transition">
                    👤
                </a>

                <!-- LOGOUT -->
                <form asp-controller="Auth"
                      asp-action="Logout"
                      method="post"
                      class="inline">
                    <button type="submit"
                            class="relative
                                       after:content-[''] after:absolute after:left-0 after:-bottom-1
                                       after:w-0 after:h-[1px] after:bg-black
                                       after:transition-all after:duration-300
                                       hover:after:w-full">
                        Cerrar sesión
                    </button>
                </form>
            }
            else
            {
                <!-- LOGIN -->
                <a href="/Auth/Login"
                   class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                    Iniciar sesión
                </a>
            }

            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Index"
                   class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                    Admin
                </a>
            }

            @if (User.IsInRole("Empresa"))
            {
                <a href="/Empresa/Dashboard"
                   class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                    Empresa
                </a>
            }

        </div>
    </div>
</header>
<div class="max-w-3xl mx-auto mt-10 bg-white p-6 rounded-xl shadow-md">
    <h1 class="text-3xl font-bold mb-6">Crear Nueva Ruta</h1>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="text-red-600 mb-2">
            @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="CrearRuta" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-danger"></div>

        <label>Ciudad Origen</label>
        <select asp-for="CiudadOrigenId"
                asp-items="@(new SelectList(ViewBag.Ciudades, "CiudadId", "Nombre"))">
            <option value="">Seleccione</option>
        </select>

        <label>Ciudad Destino</label>
        <select asp-for="CiudadDestinoId"
                asp-items="@(new SelectList(ViewBag.Ciudades, "CiudadId", "Nombre"))">
            <option value="">Seleccione</option>
        </select>

        <label>Precio</label>
        <input asp-for="Precio" type="number" step="0.01" />

        <label>Duración (min)</label>
        <input asp-for="DuracionMin" type="number" />

        <label>Fecha Salida</label>
        <input asp-for="FechaSalida" type="datetime-local" />

        <label>Fecha Llegada</label>
        <input asp-for="FechaLlegada" type="datetime-local" />

        <button type="submit">Crear Ruta</button>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const success = '@TempData["SuccessMessage"]';
            const error = '@TempData["ErrorMessage"]';

            if (success) {
                Swal.fire("Éxito", success, "success");
            }

            if (error) {
                Swal.fire("Error", error, "error");
            }
        });
    </script>
}
