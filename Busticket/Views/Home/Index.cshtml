@{
    ViewBag.Title = "Busticket - Home";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Busticket</title>

    <!-- Fuente -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        /* Estado inicial (oculto) */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

            /* Estado visible */
            .reveal.active {
                opacity: 1;
                transform: translateY(0);
            }
    </style>
</head>

<body class="bg-black text-white antialiased">

    <!-- HEADER -->
    <header class="fixed top-0 inset-x-0 z-50">
        <div class="max-w-7xl mx-auto px-10 py-6 flex items-center justify-between">

            <a 
               class="text-2xl tracking-widest uppercase font-semibold">
                Busticket
            </a>
            
            @* Boton para abrir el menú móvil, solo visible en pantallas pequeñas *@
            <button id="menuBtn" class="md:hidden text-2xl z-50 relative">
                ☰
            </button>

            <div class="hidden md:flex gap-10 text-sm tracking-widest uppercase items-center">

                <a href="/Ayuda"
                   class="relative after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[1px]
                          after:bg-white after:transition-all after:duration-300 hover:after:w-full">
                    Ayuda
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/Perfil"
                       class="flex items-center justify-center w-10 h-10
                                  rounded-full border border-white
                                  hover:bg-white hover:text-black transition">
                        👤
                    </a>

                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit"
                                class="relative after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[1px]
                                           after:bg-white after:transition-all after:duration-300 hover:after:w-full">
                            Cerrar sesión
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Auth/Login"
                       class="relative after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[1px]
                                  after:bg-white after:transition-all after:duration-300 hover:after:w-full">
                        Iniciar sesión
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index"
                       class="relative after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[1px]
                                  after:bg-white after:transition-all after:duration-300 hover:after:w-full">
                        Admin
                    </a>
                }

                @if (User.IsInRole("Empresa"))
                {
                    <a href="/PanelEmpresa/Index"
                       class="relative after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[1px]
                                  after:bg-white after:transition-all after:duration-300 hover:after:w-full">
                        Empresa
                    </a>
                }
            </div>
        </div>
    </header>

    @* Informacion del menu movile   *@   
    <div id="mobileMenu"
         class="fixed inset-0 bg-black/80 backdrop-blur-sm
            flex flex-col items-center justify-center
            space-y-8 uppercase tracking-widest text-lg
            transform -translate-y-full
            transition-transform duration-500
            md:hidden z-40">

        <a href="/Ayuda">Ayuda</a>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a href="/Perfil">Perfil</a>

            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit">Cerrar sesión</button>
            </form>
        }
        else
        {
            <a href="/Auth/Login">Iniciar sesión</a>
        }

        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Index">Admin</a>
        }

        @if (User.IsInRole("Empresa"))
        {
            <a href="/PanelEmpresa/Index">Empresa</a>
        }
    </div>

    <!-- HERO -->
    <section class="relative h-screen w-full">

        <img src="https://res.cloudinary.com/dbt58u6ag/image/upload/f_auto,q_auto,w_1920/imagen_fondo_d86xtq.jpg"
             class="absolute inset-0 w-full h-full object-cover" />

        <div class="absolute inset-0 bg-black/60"></div>

        <div class="relative z-10 flex items-center h-full">
            <div class="max-w-7xl mx-auto px-10">

                <h1 class="text-4xl md:text-6xl font-semibold mb-6">
                    La nueva forma<br />de viajar en bus
                </h1>

              
              

                <a href="/Rutas/Index"
                   class="relative uppercase tracking-widest text-sm
                          after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[1px]
                          after:bg-white after:transition-all after:duration-300 hover:after:w-full">
                    Buscar rutas
                </a>
            </div>
        </div>
    </section>

    <!-- QUÉ ES -->
    <section class="py-24 reveal">
     
        <div class="max-w-7xl mx-auto px-10 text-center">
            <h2 class="text-3xl md:text-4xl font-semibold mb-6">
                Viajar en bus nunca fue tan fácil
            </h2>
            <p class="text-white/70 max-w-3xl mx-auto">
                Busticket es una plataforma que te permite buscar rutas,
                comparar precios y comprar boletos de bus en un solo lugar.
            </p>
        </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <section class="bg-neutral-950 py-24 reveal">
        <div class="max-w-7xl mx-auto px-10">
            <h2 class="text-3xl md:text-4xl font-semibold text-center mb-16">
                ¿Cómo funciona?
            </h2>

            <div class="grid md:grid-cols-3 gap-12 text-center">
                <div class="reveal">
                    <h3 class="text-xl mb-4">Busca tu ruta</h3>
                    <p class="text-white/70">Origen, destino y fecha.</p>
                </div>
                <div class="reveal">
                    <h3 class="text-xl mb-4">Compara opciones</h3>
                    <p class="text-white/70">Horarios, precios y empresas.</p>
                </div>
                <div class="reveal">
                    <h3 class="text-xl mb-4">Compra y viaja</h3>
                    <p class="text-white/70">Pago seguro y boleto inmediato.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- BENEFICIOS -->
    <section class="py-24 reveal">
        <div class="max-w-7xl mx-auto px-10">
            <h2 class="text-3xl md:text-4xl font-semibold text-center mb-16">
                ¿Por qué Busticket?
            </h2>

            <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto text-white/80">
                <div class="reveal">✔ Compra 100% en línea</div>
                <div class="reveal">✔ Varias empresas</div>
                <div class="reveal">✔ Sin filas</div>
                <div class="reveal">✔ Pago seguro</div>
                <div class="reveal">✔ Acceso móvil</div>
                <div class="reveal">✔ Confirmación inmediata</div>
            </div>
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="bg-neutral-950 py-24 text-center reveal">
        <h2 class="text-3xl md:text-4xl font-semibold mb-8">
            ¿Listo para tu próximo viaje?
        </h2>

        <a href="/Rutas/Index"
           class="relative uppercase tracking-widest text-sm
                  after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[1px]
                  after:bg-white after:transition-all after:duration-300 hover:after:w-full">
            Buscar rutas
        </a>
    </section>

    <!-- SCRIPT DE ANIMACIÓN -->
    <script>
        const reveals = document.querySelectorAll('.reveal');

        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    observer.unobserve(entry.target);
                }
            });
        }, {
            threshold: 0.15
        });

        reveals.forEach(el => observer.observe(el));
            
        
    </script>
    
    @* Script para abrir /cerrar el menú móvil  *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const menuBtn = document.getElementById("menuBtn");
            const mobileMenu = document.getElementById("mobileMenu");

            let isOpen = false;

            menuBtn.addEventListener("click", function () {

                isOpen = !isOpen;

                if (isOpen) {
                    mobileMenu.classList.remove("-translate-y-full");
                    menuBtn.textContent = "✕";
                } else {
                    mobileMenu.classList.add("-translate-y-full");
                    menuBtn.textContent = "☰";
                }

            });

        });
    </script>
    
    
    @* codigo para el chatbot *@
    <div class="fixed bottom-4 right-4 z-[9999] flex flex-col items-end font-sans">

        <div id="chat-box" class="hidden flex-col mb-4 w-[90vw] sm:w-80 h-[500px] bg-white border border-gray-200 rounded-2xl shadow-2xl overflow-hidden transition-all duration-300">

            <div class="bg-gradient-to-r from-blue-600 to-blue-800 p-4 flex justify-between items-center text-white shadow-md">
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center border border-white/30">
                            <span class="text-xl">🤖</span>
                        </div>
                        <div class="absolute bottom-0 right-0 w-3 h-3 bg-green-400 border-2 border-white rounded-full"></div>
                    </div>
                    <div>
                        <p class="text-sm font-bold leading-tight">Asistente Virtual</p>
                        <p class="text-[10px] text-blue-100 uppercase tracking-wider">En línea ahora</p>
                    </div>
                </div>
                <button onclick="toggleChat()" class="hover:bg-white/20 rounded-full p-2 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div id="chat-content" class="flex-1 p-4 overflow-y-auto space-y-4 bg-slate-50 flex flex-col custom-scrollbar">
                <div class="bg-blue-100 p-3 rounded-2xl rounded-tl-none text-blue-900 self-start max-w-[85%] shadow-sm border border-blue-200">
                    <p class="text-xs font-semibold mb-1">Betty</p>
                    ¡Hola! soy Betty. Y no logro entender por que Gabriel es tan pero tan sapo.
                </div>
            </div>

            <div id="typing-indicator" class="hidden px-4 py-2 bg-slate-50 text-[10px] text-gray-400 italic">
                Betty está analizando...
            </div>

            <div class="p-3 bg-white border-t border-gray-100">
                <div class="relative flex items-center">
                    <input type="text" id="user-input"
                           class="w-full bg-gray-100 border-none rounded-full pl-4 pr-12 py-3 text-sm text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
                           placeholder="Escribe tu mensaje..."
                           onkeypress="if(event.key === 'Enter') enviarMensaje()">

                    <button onclick="enviarMensaje()" class="absolute right-1 bg-blue-600 text-white p-2 rounded-full hover:bg-blue-700 transition-all active:scale-90 shadow-md">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 rotate-90" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <button onclick="toggleChat()" class="group relative bg-blue-600 hover:bg-blue-700 text-white p-4 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-1 active:scale-95">
            <span class="absolute -top-1 -right-1 flex h-4 w-4">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-4 w-4 bg-red-500 text-[10px] items-center justify-center font-bold">1</span>
            </span>
            <svg id="chat-icon" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 transition-transform group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
        </button>
    </div>

    <script>
        function toggleChat() {
            const chatBox = document.getElementById('chat-box');
            chatBox.classList.toggle('hidden');
            chatBox.classList.toggle('flex');
        }

        async function enviarMensaje() {
            const input = document.getElementById('user-input');
            const content = document.getElementById('chat-content');
            const typing = document.getElementById('typing-indicator');
            const mensaje = input.value.trim();

            if (!mensaje) return;

            // 1. Agregar mensaje del usuario al diseño
            content.innerHTML += `
                <div class="bg-blue-600 text-white p-3 rounded-2xl rounded-tr-none self-end max-w-[85%] shadow-md ml-auto text-sm">
                    ${mensaje}
                </div>`;

            input.value = "";
            content.scrollTop = content.scrollHeight;
            typing.classList.remove('hidden'); // Mostrar que la IA está pensando

            try {
                // 2. Llamada al controlador ChatBotController (Stateless Request)
                const response = await fetch('/api/ChatBot/preguntar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mensaje: mensaje })
                });

                const data = await response.json();

                // 3. Agregar respuesta de Gemini
                content.innerHTML += `
                    <div class="bg-white border border-gray-200 p-3 rounded-2xl rounded-tl-none text-gray-800 self-start max-w-[85%] shadow-sm text-sm">
                        <p class="text-[10px] font-bold text-blue-600 mb-1 uppercase">Respuesta:</p>
                        ${data.respuesta}
                    </div>`;

            } catch (error) {
                console.error("Error en el chatbot:", error);
                content.innerHTML += `<div class="text-red-500 text-xs text-center">Error de conexión.</div>`;
            } finally {
                typing.classList.add('hidden'); // Ocultar indicador
                content.scrollTop = content.scrollHeight;
            }
        }
    </script>

    <style>
        /* Estilo para que el scroll del chat sea más bonito */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
    </style>
</body>
</html>