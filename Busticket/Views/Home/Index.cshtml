@{
    ViewBag.Title = "Busticket - Home";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Busticket</title>

    <!-- Fuente -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .animate-fade {
            animation: fadeIn 1.5s ease forwards;
        }
    </style>
</head>

<body class="bg-black text-white antialiased">
    <!-- HEADER -->
    <header class="absolute top-0 inset-x-0 z-50 animate-fade">
        <div class="max-w-7xl mx-auto px-10 py-8 flex items-center justify-between text-black">

            <!-- NAV -->
            <nav class="hidden md:flex gap-10 text-xs tracking-widest uppercase text-black">
                <a href="/Rutas/Index" class="hover:text-white">Planes</a>
            </nav>

            <!-- LOGO -->
            <a href="/Home/Index"
               class="text-xl tracking-widest uppercase font-light text-black">
                Busticket
            </a>

            <!-- USER ACTIONS -->
            <div class="flex gap-8 text-xs tracking-widest uppercase text-black items-center">

                <a href="/Soporte" class="hover:text-white">Ayuda</a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <!-- LOGUEADO -->
                    <a href="/Perfil"
                       title="Mi cuenta"
                       class="flex items-center justify-center w-8 h-8 rounded-full border border-black hover:bg-black hover:text-white transition">
                        👤
                    </a>

                    <form asp-controller="Auth"
                          asp-action="Logout"
                          method="post"
                          class="inline">
                        <button type="submit"
                                class="hover:text-white">
                            Cerrar sesión
                        </button>
                    </form>
                }
                else
                {
                    <!-- NO LOGUEADO -->
                    <a href="/Auth/Login" class="hover:text-white">
                        Iniciar sesión
                    </a>
                }

            </div>

        </div>
    </header>



    <!-- HERO -->
    <section class="relative h-screen w-full animate-fade">
        <video class="absolute inset-0 w-full h-full object-cover"
               autoplay
               muted
               loop
               playsinline>

            <source src="https://res.cloudinary.com/dbt58u6ag/video/upload/v1768331307/Grabaci%C3%B3n_2026-01-13_140805_eusjux.mp4"
                    type="video/mp4">
        </video>
        <!-- Contenido -->
        <div class="absolute inset-0 flex items-center">
            <div class="max-w-7xl mx-auto px-10">

               

                <h1 class="text-4xl md:text-6xl font-light tracking-wide leading-tight mb-10">
                    La nueva forma<br />
                    de viajar
                </h1>

                <a href="/Rutas/Index"
                   class="inline-block text-sm tracking-widest uppercase
                      border-b border-white pb-1
                      hover:opacity-70 transition">
                    Buscar rutas
                </a>

            </div>
        </div>

    </section>

</body>
</html>
