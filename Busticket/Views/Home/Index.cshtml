@{
    ViewBag.Title = "Busticket - Home";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Busticket</title>

    <!-- Fuente -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .animate-fade {
            animation: fadeIn 1.5s ease forwards;
        }
    </style>
</head>


<body class="bg-black text-white antialiased">

    <!-- HEADER -->
    <header class="absolute top-0 inset-x-0 z-50">
        <div class="max-w-7xl mx-auto px-10 py-6
                    flex items-center justify-between
                    text-white">

            <!-- NAV -->
        

            <!-- LOGO -->
            <a href="/Home/Index"
               class="text-2xl tracking-widest uppercase font-semibold">
                Busticket
            </a>

            <!-- USER ACTIONS -->
            <div class="flex gap-10 text-sm tracking-widest uppercase items-center">
                <a href="/Ayuda"
                   class="relative uppercase tracking-widest text-sm
          after:content-[''] after:absolute after:left-0 after:-bottom-1
          after:w-0 after:h-[1px] after:bg-white
          after:transition-all after:duration-300
          hover:after:w-full">
                    Ayuda
                </a>


                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/Perfil"
                       title="Mi cuenta"
                       class="flex items-center justify-center w-10 h-10
                                  rounded-full border border-white
                                  hover:bg-white hover:text-black transition">
                        👤
                    </a>

                    <form asp-controller="Auth"
                          asp-action="Logout"
                          method="post"
                          class="inline">
                        <button type="submit"
                                class="relative uppercase tracking-widest text-sm
                   after:content-[''] after:absolute after:left-0 after:-bottom-1
                   after:w-0 after:h-[1px] after:bg-white
                   after:transition-all after:duration-300
                   hover:after:w-full">
                            Cerrar sesión
                        </button>

                    </form>
                }
                else
                {
                    <a href="/Auth/Login"
                       class="relative uppercase tracking-widest text-sm
              after:content-[''] after:absolute after:left-0 after:-bottom-1
              after:w-0 after:h-[1px] after:bg-white
              after:transition-all after:duration-300
              hover:after:w-full">
                        Iniciar sesión
                    </a>

                }
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index"
                       class="relative uppercase tracking-widest text-sm
                  after:content-[''] after:absolute after:left-0 after:-bottom-1
                  after:w-0 after:h-[1px] after:bg-white
                  after:transition-all after:duration-300
                  hover:after:w-full">
                        Admin
                    </a>
                }
                @if (User.IsInRole("Empresa"))
                {
                    <a href="/Empresa/Dashboard"
                       class="relative uppercase tracking-widest text-sm
                  after:content-[''] after:absolute after:left-0 after:-bottom-1
                  after:w-0 after:h-[1px] after:bg-white
                  after:transition-all after:duration-300
                  hover:after:w-full">
                        Empresa
                    </a>
                }

    
            </div>
        </div>
    </header>

    <!-- HERO -->
    <section class="relative h-screen w-full">

        <!-- IMAGEN -->
        <img src="https://res.cloudinary.com/dbt58u6ag/image/upload/f_auto,q_auto,w_1920/imagen_fondo_d86xtq.jpg"
             alt="Fondo de montaña"
             class="absolute inset-0 w-full h-full object-cover" />

        <!-- OVERLAY OSCURO -->
        <div class="absolute inset-0 bg-black/60"></div>

        <!-- CONTENIDO -->
        <div class="relative z-10 flex items-center h-full">
            <div class="max-w-7xl mx-auto px-10">

                <h1 class="text-4xl md:text-6xl font-semibold tracking-wide leading-tight mb-10">
                    La nueva forma<br />
                    de viajar
                </h1>

                <a href="/Rutas/Index"
                   class="relative uppercase tracking-widest text-sm
          after:content-[''] after:absolute after:left-0 after:-bottom-1
          after:w-0 after:h-[1px] after:bg-white
          after:transition-all after:duration-300
          hover:after:w-full">
                    Buscar rutas
                </a>



            </div>
        </div>

    </section>

</body>


</html>
