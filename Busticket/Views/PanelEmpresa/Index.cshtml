@model Busticket.Models.ViewModels.PanelEmpresaVM

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50 text-gray-800">
    <!-- HEADER -->
    <header class="absolute top-0 inset-x-0 z-50">
        <div class="max-w-7xl mx-auto px-10 py-6
                flex items-center justify-between
                text-black">

            <!-- IZQUIERDA -->
            <div class="flex items-center gap-6">

                <!-- BOTÓN VOLVER -->
                @if (Context.Request.Path != "/Home/Index")
                {
                    <button onclick="history.back()"
                            class="flex items-center gap-2 text-sm tracking-widest uppercase
                                   opacity-80 hover:opacity-100 transition group">

                        <!-- ICONO FLECHA SVG -->
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-5 h-5 transform group-hover:-translate-x-1 transition duration-300"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M15 19l-7-7 7-7" />
                        </svg>

                        Volver
                    </button>
                }

                <!-- LOGO -->
                <a href="/Home/Index"
                   class="text-2xl tracking-widest uppercase font-semibold">
                    Busticket
                </a>

            </div>

            <!-- DERECHA -->
            <div class="flex gap-10 text-sm tracking-widest uppercase items-center">

                <!-- AYUDA -->
                <a href="/Ayuda"
                   class="relative
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-black
                      after:transition-all after:duration-300
                      hover:after:w-full">
                    Ayuda
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <!-- PERFIL -->
                    <a href="/Perfil"
                       title="Mi cuenta"
                       class="flex items-center justify-center w-10 h-10
                              rounded-full border border-black
                              hover:bg-black hover:text-white transition">
                        👤
                    </a>

                    <!-- LOGOUT -->
                    <form asp-controller="Auth"
                          asp-action="Logout"
                          method="post"
                          class="inline">
                        <button type="submit"
                                class="relative
                                       after:content-[''] after:absolute after:left-0 after:-bottom-1
                                       after:w-0 after:h-[1px] after:bg-black
                                       after:transition-all after:duration-300
                                       hover:after:w-full">
                            Cerrar sesión
                        </button>
                    </form>
                }
                else
                {
                    <!-- LOGIN -->
                    <a href="/Auth/Login"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Iniciar sesión
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Admin
                    </a>
                }

                @if (User.IsInRole("Empresa"))
                {
                    <a href="/Empresa/Dashboard"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Empresa
                    </a>
                }

            </div>
        </div>
    </header>

    <!-- CONTENIDO -->
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

        <h1 class="text-3xl sm:text-4xl font-bold text-gray-800 mb-12 text-center">
            Panel de Empresa
        </h1>

        <!-- BOTONES PRINCIPALES -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-14">

            <a asp-controller="PanelEmpresa" asp-action="Rutas"
               class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-4 rounded-xl shadow-md text-center font-semibold transition">
                Ver Rutas
            </a>

        </div>

        <!-- FILTROS -->
        <div class="bg-white p-6 rounded-xl shadow mb-8">

            <div class="flex flex-col sm:flex-row sm:flex-wrap gap-6 sm:items-end">

                <div class="flex flex-col">
                    <label class="text-sm font-semibold text-gray-600 mb-1">Desde</label>
                    <input type="date" id="fechaInicio"
                           class="border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>

                <div class="flex flex-col">
                    <label class="text-sm font-semibold text-gray-600 mb-1">Hasta</label>
                    <input type="date" id="fechaFin"
                           class="border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>

                <button type="button"
                        onclick="filtrarTabla()"
                        class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition">
                    Filtrar
                </button>

                <button type="button"
                        onclick="exportarExcel()"
                        class="sm:ml-auto bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition">
                    Descargar Excel
                </button>

            </div>
        </div>

        <!-- TABLA -->
        <div class="bg-white shadow-lg rounded-xl overflow-hidden">

            <div class="overflow-x-auto">
                <table id="tablaVentas" class="w-full text-sm text-left">

                    <thead class="bg-gray-100 text-gray-700 uppercase text-xs tracking-wider">
                        <tr>
                            <th class="px-6 py-3">Venta ID</th>
                            <th class="px-6 py-3">Usuario</th>
                            <th class="px-6 py-3">Empresa</th>
                            <th class="px-6 py-3">Fecha</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Ventas)
                        {
                            <tr class="border-t hover:bg-gray-50 transition"
                                data-fecha="@item.Fecha.ToString("yyyy-MM-dd")">

                                <td class="px-6 py-4 font-medium">
                                    @item.VentaId
                                </td>

                                <td class="px-6 py-4">
                                    @item.User?.UserName
                                </td>

                                <td class="px-6 py-4">
                                    @item.Empresa?.Nombre
                                </td>

                                <td class="px-6 py-4">
                                    @item.Fecha.ToString("dd/MM/yyyy")
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>

    </div>

    <script src="~/js/admin.js"></script>

</body>
</html>