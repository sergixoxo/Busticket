@model List<Busticket.Models.Ruta>

@{
    Layout = null;
}
<script src="https://cdn.tailwindcss.com"></script>

<div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- TÍTULO + BOTÓN -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8 gap-4">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
            Listado de Rutas
        </h1>

        <a asp-controller="PanelEmpresa"
           asp-action="CrearRuta"
           class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg shadow-md transition text-center">
            + Crear Ruta
        </a>
    </div>

    <!-- TABLA -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left border-collapse min-w-[700px]">

                <thead class="bg-gray-100 text-gray-700 uppercase text-xs tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Origen</th>
                        <th class="px-6 py-4">Destino</th>
                        <th class="px-6 py-4">Precio</th>
                        <th class="px-6 py-4">Empresa</th>
                        <th class="px-6 py-4 text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-gray-200">

                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition">

                            <td class="px-6 py-4 font-medium">
                                @item.CiudadOrigen.Nombre
                            </td>

                            <td class="px-6 py-4">
                                @item.CiudadDestino.Nombre
                            </td>

                            <td class="px-6 py-4">
                                $@item.Precio
                            </td>

                            <td class="px-6 py-4">
                                @item.Empresa?.Nombre
                            </td>

                            <td class="px-6 py-4">
                                <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">

                                    <a asp-action="EditarRuta"
                                       asp-route-id="@item.RutaId"
                                       class="text-yellow-600 hover:text-yellow-700 font-medium">
                                        Editar
                                    </a>

                                    <a asp-action="EliminarRuta"
                                       asp-route-id="@item.RutaId"
                                       class="text-red-600 hover:text-red-700 font-medium">
                                        Eliminar
                                    </a>

                                </div>
                            </td>

                        </tr>
                    }

                </tbody>
            </table>
        </div>

    </div>

</div>
