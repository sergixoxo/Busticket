@model Busticket.Models.PerfilViewModel
@{
    Layout = null;
    <partial name="_DarkModeScript" />
}
<script src="https://cdn.tailwindcss.com"></script>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="~/css/ModeDark.css" rel="stylesheet">

    <style>
       * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: var(--bg-body);
            color: var(--text-titulo);
            transition: background 0.3s ease, color 0.3s ease;
        }

        .perfil {
            display: flex;
            justify-content: center;
            align-items: stretch;
            min-height: 100vh;
        }

        .panel {
            display: flex;
            width: 100%;
            background: var(--bg-panel);
            transition: background 0.3s ease;
        }

        .contenido {
            width: 60%;
            padding: 50px 70px;
        }

        .foto-panel {
            width: 40%;
            background: var(--bg-foto-panel);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 18px;
            transition: background 0.3s ease;
        }

        .logo {
            font-weight: 800;
            font-size: 26px;
            color: var(--text-main);
            margin-bottom: 20px;
        }

        .titulo {
            font-size: 30px;
            font-weight: 700;
            margin-bottom: 25px;
            color: var(--text-titulo);
        }

        .card {
            background: var(--bg-card);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 18px;
            transition: background 0.3s ease;
        }

        .card-historial {
            max-height: 300px;
            overflow-y: auto;
            padding-right: 10px;
        }

        .info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .dato {
            background: var(--bg-dato);
            padding: 10px 12px;
            border-radius: 6px;
            font-size: 14px;
            transition: background 0.3s ease;
        }

        .label {
            font-size: 12px;
            color: var(--text-label);
        }

        .valor {
            font-weight: 600;
            color: var(--text-titulo);
        }

        .historial-item {
            background: var(--bg-dato);
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            transition: background 0.3s ease;
        }

        .btn {
            margin-top: 10px;
            background: #1d3557;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            font-size: 14px;
        }

        /* --- Estilos del Switch (Checkbox) --- */
        .theme-switch-container {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 15px;
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 46px;
            height: 22px;
        }

            .switch input {
                opacity: 0;
                width: 0;
                height: 0;
            }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 34px;
        }

            .slider:before {
                position: absolute;
                content: "";
                height: 16px;
                width: 16px;
                left: 3px;
                bottom: 3px;
                background-color: white;
                transition: .4s;
                border-radius: 50%;
            }

        input:checked + .slider {
            background-color: #457b9d;
        }

            input:checked + .slider:before {
                transform: translateX(24px);
            }

        #theme-text {
            font-size: 14px;
            font-weight: 500;
        }

        .foto {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            overflow: hidden;
            border: 4px solid var(--text-main);
        }

            .foto img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        input[type=file] {
            display: none;
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 1024px) {
            .panel {
                flex-direction: column;
            }

            .contenido, .foto-panel {
                width: 100%;
                padding: 30px 20px;
            }

            .info {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- HEADER -->
    <header class="absolute top-0 inset-x-0 z-50">
        <div class="max-w-7xl mx-auto px-10 py-6
                flex items-center justify-between
                text-black">

            <!-- IZQUIERDA -->
            <div class="flex items-center gap-6">

                <!-- BOTÓN VOLVER -->
                @if (Context.Request.Path != "/Home/Index")
                {
                    <button onclick="history.back()"
                            class="flex items-center gap-2 text-sm tracking-widest uppercase
                                   opacity-80 hover:opacity-100 transition group">

                        <!-- ICONO FLECHA SVG -->
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-5 h-5 transform group-hover:-translate-x-1 transition duration-300"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M15 19l-7-7 7-7" />
                        </svg>

                        Volver
                    </button>
                }

                <!-- LOGO -->
                <a href="/Home/Index"
                   class="text-2xl tracking-widest uppercase font-semibold">
                    Busticket
                </a>

            </div>

            <!-- DERECHA -->
            <div class="flex gap-10 text-sm tracking-widest uppercase items-center">

                <!-- AYUDA -->
                <a href="/Ayuda"
                   class="relative
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-black
                      after:transition-all after:duration-300
                      hover:after:w-full">
                    Ayuda
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <!-- PERFIL -->
                    <a href="/Perfil"
                       title="Mi cuenta"
                       class="flex items-center justify-center w-10 h-10
                              rounded-full border border-black
                              hover:bg-black hover:text-white transition">
                        👤
                    </a>

                    <!-- LOGOUT -->
                    <form asp-controller="Auth"
                          asp-action="Logout"
                          method="post"
                          class="inline">
                        <button type="submit"
                                class="relative
                                       after:content-[''] after:absolute after:left-0 after:-bottom-1
                                       after:w-0 after:h-[1px] after:bg-black
                                       after:transition-all after:duration-300
                                       hover:after:w-full">
                            Cerrar sesión
                        </button>
                    </form>
                }
                else
                {
                    <!-- LOGIN -->
                    <a href="/Auth/Login"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Iniciar sesión
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Admin
                    </a>
                }

                @if (User.IsInRole("Empresa"))
                {
                    <a href="/Empresa/Dashboard"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Empresa
                    </a>
                }

            </div>
        </div>
    </header>

    <script>
        // Aplicar tema antes de renderizar para evitar parpadeo
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>

    <div class="perfil">
        <div class="panel">
            <div class="contenido">
                <div class="logo">Busticket</div>
                <div class="titulo">Mi Perfil</div>

                <div class="card">
                    <h3>Información personal</h3>
                    <div class="info">
                        <div class="dato">
                            <div class="label">Nombre</div>
                            <div class="valor">@Model.Nombre</div>
                        </div>
                        <div class="dato">
                            <div class="label">Correo</div>
                            <div class="valor">@Model.Correo</div>
                        </div>
                        <div class="dato">
                            <div class="label">Teléfono</div>
                            <div class="valor">@Model.Telefono</div>
                        </div>
                    </div>
                </div>

                <div class="card card-historial">
                    <h3>Historial de viajes</h3>
                    @foreach (var viaje in Model.HistorialViajes)
                    {
                        <div class="historial-item">
                            <span>@viaje.Origen → @viaje.Destino</span>
                            <span>@viaje.Fecha.ToString("dd MMM yyyy")</span>
                        </div>
                    }
                </div>

                <div class="card">
               
                    <div class="theme-switch-container">
                        <label class="switch">
                            <input type="checkbox" id="checkboxTheme">
                            <span class="slider"></span>
                        </label>
                        <span id="theme-text">Activar Modo Oscuro</span>
                    </div>
                </div>
            </div>

            <div class="foto-panel">
                <div class="foto">
                    <img id="preview" src="https://res.cloudinary.com/dbt58u6ag/image/upload/v1771867385/basic_e5v9wv.png" />
                </div>
                <label class="btn">
                    Cambiar foto
                    <input type="file" id="inputFoto" accept="image/*" />
                </label>
            </div>
        </div>
    </div>

    <script>
        const checkboxTheme = document.getElementById('checkboxTheme');
        const themeText = document.getElementById('theme-text');
        const inputFoto = document.getElementById('inputFoto');
        const preview = document.getElementById('preview');

        // Función para sincronizar la UI con el tema actual
        function actualizarInterfaz() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            checkboxTheme.checked = isDark;
            themeText.innerText = isDark ? "Activar Modo Claro" : "Activar Modo Oscuro";
        }

        // Ejecutar al cargar la página
        actualizarInterfaz();

        // Lógica del Checkbox
        checkboxTheme.addEventListener('change', () => {
            const newTheme = checkboxTheme.checked ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            actualizarInterfaz();
        });

        // Cambio de foto
        inputFoto.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = e => preview.src = e.target.result;
                reader.readAsDataURL(file);
            }
        });
    </script>
</body>
</html>