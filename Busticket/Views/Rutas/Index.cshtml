@model List<Busticket.Models.Ruta>

@{
    ViewBag.Title = "Rutas";
    Layout = null;

    var destinoSeleccionado = Context.Request.Query["destino"].ToString();
}
<partial name="_DarkModeScript" />

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="~/css/ModeDark.css" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-up {
            animation: fadeUp .6s ease-out forwards;
        }
    </style>
</head>
<!-- HEADER -->
<header class="absolute top-0 inset-x-0 z-50">
    <div class="max-w-7xl mx-auto px-10 py-6
                    flex items-center justify-between
                    text-black">

        <!-- NAV -->
        <!-- LOGO -->
        <a href="/Home/Index"
           class="text-2xl tracking-widest uppercase font-semibold">
            Busticket
        </a>

        @* Boton para abrir el menú móvil, solo visible en pantallas pequeñas *@
        <button id="menuBtn" class="md:hidden text-2xl z-50 relative text-gray-900">
            ☰
        </button>

        <!-- USER ACTIONS -->
        <div class="hidden md:flex gap-10 text-sm tracking-widest uppercase items-center">
            <a href="/Ayuda"
               class="relative uppercase tracking-widest text-sm
          after:content-[''] after:absolute after:left-0 after:-bottom-1
          after:w-0 after:h-[1px] after:bg-white
          after:transition-all after:duration-300
          hover:after:w-full">
                Ayuda
            </a>


            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a href="/Perfil"
                   title="Mi cuenta"
                   class="flex items-center justify-center w-10 h-10
                                          rounded-full border border-white
                                          hover:bg-white hover:text-black transition">
                    👤
                </a>

                <form asp-controller="Auth"
                      asp-action="Logout"
                      method="post"
                      class="inline">
                    <button type="submit"
                            class="relative uppercase tracking-widest text-sm
                           after:content-[''] after:absolute after:left-0 after:-bottom-1
                           after:w-0 after:h-[1px] after:bg-white
                           after:transition-all after:duration-300
                           hover:after:w-full">
                        Cerrar sesión
                    </button>

                </form>
            }
            else
            {
                <a href="/Auth/Login"
                   class="relative uppercase tracking-widest text-sm
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-white
                      after:transition-all after:duration-300
                      hover:after:w-full">
                    Iniciar sesión
                </a>

            }
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Index"
                   class="relative uppercase tracking-widest text-sm
                          after:content-[''] after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-white
                          after:transition-all after:duration-300
                          hover:after:w-full">
                    Admin
                </a>
            }
            @if (User.IsInRole("Empresa"))
            {
                <a href="/Empresa/Index"
                   class="relative uppercase tracking-widest text-sm
                          after:content-[''] after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-white
                          after:transition-all after:duration-300
                          hover:after:w-full">
                    Empresa
                </a>
            }


        </div>
    </div>
</header>

 @* Informacion del menu movile   *@   
    <div id="mobileMenu" class="fixed inset-0 bg-black/80 backdrop-blur-sm
            flex flex-col items-center justify-center
            space-y-8 uppercase tracking-widest text-lg
            transform -translate-y-full
            transition-transform duration-500
            md:hidden z-40 text-white">

    <a href="/Ayuda">Ayuda</a>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <a href="/Perfil">Perfil</a>

        <form asp-controller="Auth" asp-action="Logout" method="post">
            <button type="submit">Cerrar sesión</button>
        </form>
    }
    else
    {
        <a href="/Auth/Login">Iniciar sesión</a>
    }

    @if (User.IsInRole("Admin"))
    {
        <a href="/Admin/Index">Admin</a>
    }

    @if (User.IsInRole("Empresa"))
    {
        <a href="/PanelEmpresa/Index">Empresa</a>
    }
</div>

<body class="bg-[#f7f8fa] text-gray-800">

  
    
    <!-- CONTENIDO -->
    <main class="w-full max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-10 py-16">

        <!-- TÍTULO DINÁMICO -->
        <div class="text-center mb-14 fade-up">
            @if (!string.IsNullOrEmpty(destinoSeleccionado))
            {
                <p class="text-xs uppercase tracking-widest text-gray-500">
                    Rutas disponibles hacia
                </p>
                <h1 class="text-3xl sm:text-4xl font-semibold text-gray-900 mt-2">
                    @destinoSeleccionado
                </h1>
            }
            else
            {
                <h1 class="text-3xl sm:text-4xl font-semibold text-gray-900">
                    Destinos populares
                </h1>
                <p class="text-sm text-gray-500 mt-2">
                    Aquí comienza tu próxima aventura
                </p>
            }
        </div>

        <!-- GRID DE DESTINOS -->
        @if (string.IsNullOrEmpty(destinoSeleccionado))
        {
            <section class="
            grid
            grid-cols-1
            sm:grid-cols-2
            lg:grid-cols-3
            xl:grid-cols-4
            gap-6 lg:gap-8
        ">
                @{
                    var index = 0;
                }

                @foreach (var grupo in Model
                            .GroupBy(r => r.CiudadDestino)
                            .Select(g => new
                            {
                                Ciudad = g.Key,
                                PrecioMin = g.Min(r => r.Precio),
                                RutaEjemplo = g.First()
                            }))
                {
                    <article class="
                            group relative
                            h-[260px] sm:h-[300px]
                            rounded-2xl
                            overflow-hidden
                            cursor-pointer
                            shadow-md hover:shadow-2xl
                            transition-all duration-500
                            hover:-translate-y-1
                            fade-up
                        "
                             style="animation-delay:@(index * 0.05)s"
                             onclick="location.href='/Rutas/Listado?destino=@grupo.Ciudad.Nombre'">

                        <!-- IMAGEN -->
                        <img src="@(grupo.RutaEjemplo.ImagenUrl ??
                                                 $"https://picsum.photos/seed/{grupo.Ciudad.Nombre}/600/400")"
                             class="absolute inset-0 w-full h-full object-cover z-0
                             transition-transform duration-700 group-hover:scale-110" />

                        <!-- OVERLAY -->
                        <div class="absolute inset-0 bg-gradient-to-t
                            from-black/70 via-black/30 to-transparent z-10">
                        </div>

                        <!-- CONTENIDO TEXTO -->
                        <div class="absolute bottom-0 w-full p-5 text-white z-20">

                            <h3 class="text-lg sm:text-xl font-semibold !text-white drop-shadow-xl">
                                @grupo.Ciudad.Nombre
                            </h3>

                            <p class="text-sm !text-white mt-1 drop-shadow-xl">
                                Desde $@grupo.PrecioMin
                            </p>

                        </div>

                    </article>

                    index++;
                }
            </section>
        }

    </main>

    @* Script para abrir /cerrar el menú móvil  *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const menuBtn = document.getElementById("menuBtn");
            const mobileMenu = document.getElementById("mobileMenu");

            let isOpen = false;

            menuBtn.addEventListener("click", function () {

                isOpen = !isOpen;

                if (isOpen) {
                    mobileMenu.classList.remove("-translate-y-full");
                    menuBtn.textContent = "✕";
                } else {
                    mobileMenu.classList.add("-translate-y-full");
                    menuBtn.textContent = "☰";
                }

            });

        });
    </script>

</body>
</html>
