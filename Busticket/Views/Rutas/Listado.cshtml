@model List<Busticket.Models.Ruta>

@{
    ViewBag.Title = "Rutas disponibles";
    Layout = null;
}


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />
    <script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>

    <style>
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-up {
            animation: fadeUp .6s ease-out forwards;
        }
    </style>
</head>

<body class="bg-[#f7f8fa] text-gray-800">

    <!-- ================= NAV ================= -->
    <header class="sticky top-0 z-40 bg-white/80 backdrop-blur border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-10 py-5 flex items-center justify-between">

            <a href="/Home/Index"
               class="text-2xl tracking-widest uppercase font-semibold text-gray-900">
                Busticket
            </a>

            <div class="hidden md:flex gap-10 text-sm tracking-widest uppercase items-center">

                <a href="/Ayuda"
                   class="relative after:absolute after:left-0 after:-bottom-1
                          after:w-0 after:h-[1px] after:bg-gray-900
                          after:transition-all after:duration-300
                          hover:after:w-full">
                    Ayuda
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/Perfil"
                       class="flex items-center justify-center w-9 h-9
                                  rounded-full border border-gray-300
                                  hover:bg-gray-900 hover:text-white transition">
                        👤
                    </a>

                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit"
                                class="relative after:absolute after:left-0 after:-bottom-1
                                           after:w-0 after:h-[1px] after:bg-gray-900
                                           after:transition-all after:duration-300
                                           hover:after:w-full">
                            Cerrar sesión
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Auth/Login"
                       class="relative after:absolute after:left-0 after:-bottom-1
                                  after:w-0 after:h-[1px] after:bg-gray-900
                                  after:transition-all after:duration-300
                                  hover:after:w-full">
                        Iniciar sesión
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index"
                       class="relative after:absolute after:left-0 after:-bottom-1
                                  after:w-0 after:h-[1px] after:bg-gray-900
                                  after:transition-all after:duration-300
                                  hover:after:w-full">
                        Admin
                    </a>
                }

                @if (User.IsInRole("Empresa"))
                {
                    <a href="/Empresa/Dashboard"
                       class="relative after:absolute after:left-0 after:-bottom-1
                                  after:w-0 after:h-[1px] after:bg-gray-900
                                  after:transition-all after:duration-300
                                  hover:after:w-full">
                        Empresa
                    </a>
                }
            </div>
        </div>
    </header>

    <!-- ================= CONTENIDO ================= -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12
             grid grid-cols-1 lg:grid-cols-[280px_1fr_360px] gap-8">

        <!-- ========== FILTROS ========== -->
        <aside class="fade-up lg:sticky lg:top-24 order-1">
            <div class="bg-white/90 backdrop-blur rounded-2xl p-6 shadow-sm">
                <h2 class="text-xs uppercase tracking-widest text-gray-500 mb-6">
                    Filtros
                </h2>

                <form method="get" action="/Rutas/Listado" class="space-y-5">

                    <div>
                        <label class="text-xs uppercase text-gray-400">Desde</label>
                        <select name="origen"
                                class="mt-1 w-full rounded-lg border-gray-200 text-sm">
                            <option value="">Todas</option>
                            @foreach (var c in Model.Select(r => r.CiudadOrigen).Distinct())
                            {
                                <option value="@c.Nombre">@c.Nombre</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="text-xs uppercase text-gray-400">Hasta</label>
                        <select name="destino"
                                class="mt-1 w-full rounded-lg border-gray-200 text-sm">
                            <option value="">Todas</option>
                            @foreach (var c in Model.Select(r => r.CiudadDestino).Distinct())
                            {
                                <option value="@c.Nombre">@c.Nombre</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="text-xs uppercase text-gray-400">Fecha de salida</label>
                        <input type="date"
                               name="fechaSalida"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")"
                               class="mt-1 w-full rounded-lg border-gray-200 text-sm" />
                    </div>

                    <div>
                        <label class="text-xs uppercase text-gray-400">Fecha de llegada</label>
                        <input type="date"
                               name="fechaLlegada"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")"
                               class="mt-1 w-full rounded-lg border-gray-200 text-sm" />
                    </div>

                    <button class="w-full mt-4 py-2 rounded-full bg-gray-900 text-white text-sm
                               hover:bg-black transition">
                        Aplicar filtros
                    </button>
                </form>
            </div>
        </aside>

        <!-- ========== LISTADO DE RUTAS ========== -->
        <section class="fade-up order-2">

            <h3 class="text-xs uppercase tracking-widest text-gray-500 mb-6">
                @Model.Count rutas disponibles
            </h3>

            <div class="flex flex-col gap-6 max-h-[70vh] lg:max-h-[75vh] overflow-y-auto pr-1">

                @foreach (var ruta in Model)
                {
                    <article class="group bg-white rounded-2xl p-4 sm:p-5 shadow-sm
                                    transition-all duration-300 hover:shadow-xl hover:-translate-y-1
                                    cursor-pointer"
                             data-id="@ruta.RutaId"
                             data-origen-lat="@ruta.CiudadOrigen.Lat"
                             data-origen-lng="@ruta.CiudadOrigen.Lng"
                             data-destino-lat="@ruta.CiudadDestino.Lat"
                             data-destino-lng="@ruta.CiudadDestino.Lng"
                             onclick="location.href='/Rutas/Info/@ruta.RutaId'">

                        <div class="flex flex-col sm:flex-row gap-4 sm:gap-5 sm:items-center">

                            <img src="@(ruta.ImagenUrl ?? $"https://picsum.photos/seed/{ruta.RutaId}/300/200")"
                                 class="w-full sm:w-36 h-40 sm:h-24 rounded-xl object-cover
                                        transition-transform duration-500 group-hover:scale-105" />

                            <div class="flex-grow">
                                <p class="font-semibold text-gray-900">
                                    @ruta.CiudadOrigen.Nombre — @ruta.CiudadDestino.Nombre
                                </p>
                                <p class="text-sm text-gray-500">
                                    @ruta.Empresa.Nombre · @ruta.DuracionMin min
                                </p>
                            </div>

                            <div class="sm:text-right">
                                <p class="text-lg font-semibold text-gray-900">
                                    $@ruta.Precio.ToString("N0")
                                </p>
                                <p class="text-xs text-gray-400">COP</p>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </section>

        <!-- ========== MAPA ========== -->
        <aside class="fade-up order-3 lg:sticky lg:top-24">
            <div id="map"
                 class="w-full h-[300px] sm:h-[400px] lg:h-[360px] rounded-2xl shadow-sm">
            </div>
        </aside>

    </main>

    <!-- ================= MAPA ================= -->
    <script>
        var map = L.map('map').setView([4.6, -74.1], 6);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        var routingControl = null;

        document.querySelectorAll('[data-id]').forEach(card => {
            card.addEventListener('mouseenter', () => {
                const oLat = parseFloat(card.dataset.origenLat);
                const oLng = parseFloat(card.dataset.origenLng);
                const dLat = parseFloat(card.dataset.destinoLat);
                const dLng = parseFloat(card.dataset.destinoLng);

                if (routingControl) map.removeControl(routingControl);

                routingControl = L.Routing.control({
                    waypoints: [L.latLng(oLat, oLng), L.latLng(dLat, dLng)],
                    addWaypoints: false,
                    draggableWaypoints: false,
                    show: false
                }).addTo(map);

                map.fitBounds([[oLat, oLng], [dLat, dLng]]);
            });
        });
    </script>

</body>
</html>