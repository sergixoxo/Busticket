@model List<Busticket.Models.Ruta>

@{
    ViewBag.Title = "Rutas disponibles";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-up {
            animation: fadeUp .6s ease-out forwards;
        }
    </style>
</head>

<body class="bg-[#f7f8fa] text-gray-800">

    <!-- ================= HEADER ================= -->
    <header class="absolute top-0 inset-x-0 z-50">
        <div class="max-w-7xl mx-auto px-10 py-6 flex items-center justify-between text-black">

            <div class="flex items-center gap-6">
                @if (Context.Request.Path != "/Home/Index")
                {
                    <button onclick="history.back()"
                            class="flex items-center gap-2 text-sm uppercase opacity-80 hover:opacity-100">
                        ← Volver
                    </button>
                }

                <a href="/Home/Index" class="text-2xl uppercase font-semibold">
                    Busticket
                </a>
            </div>

            <div class="flex gap-6 text-sm uppercase items-center">
                <a href="/Ayuda">Ayuda</a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/Perfil">👤</a>

                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit">Salir</button>
                    </form>
                }
                else
                {
                    <a href="/Auth/Login">Login</a>
                }
            </div>
        </div>
    </header>

    <!-- ================= MAIN ================= -->
    <main class="max-w-7xl mx-auto px-4 pt-20 pb-12">

        <!-- BOTÓN MOBILE -->
        <button onclick="toggleFilters()"
                class="lg:hidden fixed top-5 left-5 z-50 bg-black text-white p-3 rounded-full">
            ☰
        </button>

        <!-- ================= MOBILE ================= -->
        <div class="lg:hidden flex flex-col gap-6">

            <!-- FILTROS -->
            <aside id="filtersPanel"
                   class="fixed top-0 left-0 h-full w-72 bg-white z-40
               transform -translate-x-full transition duration-300 p-4">

                <h2 class="mb-4 font-bold">Filtros</h2>

                <form method="get" action="/Rutas/Listado" class="space-y-3">

                    <select name="origen" class="w-full border p-2 rounded">
                        <option value="">Origen</option>
                        @foreach (var c in Model.Select(r => r.CiudadOrigen).Distinct())
                        {
                            <option>@c.Nombre</option>
                        }
                    </select>

                    <select name="destino" class="w-full border p-2 rounded">
                        <option value="">Destino</option>
                        @foreach (var c in Model.Select(r => r.CiudadDestino).Distinct())
                        {
                            <option>@c.Nombre</option>
                        }
                    </select>

                    <button class="w-full bg-black text-white p-2 rounded">
                        Filtrar
                    </button>
                </form>
            </aside>

            <!-- RUTAS MOBILE -->
            @foreach (var ruta in Model)
            {
                <div class="bg-white p-4 rounded-xl shadow"
                     onclick="location.href='/Rutas/Info/@ruta.RutaId'">

                    <img src="@(string.IsNullOrEmpty(ruta.ImagenUrl)
                                             ? $"https://picsum.photos/seed/{ruta.RutaId}/300/200"
                                             : ruta.ImagenUrl)"
                         class="w-full h-40 object-cover rounded mb-2" />

                    <p class="font-bold">
                        @ruta.CiudadOrigen?.Nombre → @ruta.CiudadDestino?.Nombre
                    </p>

                    <p class="text-sm text-gray-500">
                        @ruta.Empresa?.Nombre
                    </p>

                    <p class="font-bold mt-2">
                        $@ruta.Precio.ToString("N0") COP
                    </p>
                </div>
            }
        </div>

        <!-- ================= DESKTOP ================= -->
        <div class="hidden lg:grid grid-cols-[280px_1fr_360px] gap-8">

            <!-- FILTROS -->
            <aside class="fade-up">
                <div class="bg-white rounded-2xl p-6 shadow-sm">

                    <h2 class="text-xs uppercase text-gray-500 mb-6">Filtros</h2>

                    <form method="get" action="/Rutas/Listado" class="space-y-5">

                        <select name="origen" class="w-full rounded-lg border-gray-200 text-sm">
                            <option value="">Desde</option>
                            @foreach (var c in Model.Select(r => r.CiudadOrigen).Distinct())
                            {
                                <option>@c.Nombre</option>
                            }
                        </select>

                        <select name="destino" class="w-full rounded-lg border-gray-200 text-sm">
                            <option value="">Hasta</option>
                            @foreach (var c in Model.Select(r => r.CiudadDestino).Distinct())
                            {
                                <option>@c.Nombre</option>
                            }
                        </select>

                        <button class="w-full py-2 rounded-full bg-black text-white">
                            Aplicar
                        </button>
                    </form>
                </div>
            </aside>

            <!-- RUTAS (TU DISEÑO ORIGINAL) -->
            <section class="fade-up">

                <div class="flex flex-col gap-6 max-h-[70vh] overflow-y-auto">

                    @foreach (var ruta in Model)
                    {
                        <article class="group bg-white rounded-2xl p-5 shadow-sm
                            hover:shadow-2xl hover:-translate-y-2 transition cursor-pointer border"
                                 onclick="location.href='/Rutas/Info/@ruta.RutaId'">

                            <div class="flex gap-4 items-center">

                                <img src="@(string.IsNullOrEmpty(ruta.ImagenUrl)
                                                                     ? $"https://picsum.photos/seed/{ruta.RutaId}/300/200"
                                                                     : ruta.ImagenUrl)"
                                     class="w-28 h-20 rounded-xl object-cover" />

                                <div class="flex-grow">
                                    <p class="font-semibold">
                                        @ruta.CiudadOrigen?.Nombre — @ruta.CiudadDestino?.Nombre
                                    </p>

                                    <p class="text-sm text-gray-500">
                                        @ruta.Empresa?.Nombre · @ruta.DuracionMin min
                                    </p>
                                </div>

                                <div class="text-right">
                                    <p class="font-bold">$@ruta.Precio.ToString("N0")</p>
                                    <p class="text-xs text-gray-400">COP</p>
                                </div>

                            </div>
                        </article>
                    }
                </div>
            </section>

            <!-- MAPA -->
            <aside>
                <div id="map" class="w-full h-[360px] rounded-2xl"></div>
            </aside>

        </div>

    </main>

    <!-- ================= JS ================= -->
    <script>
        function toggleFilters() {
            document.getElementById("filtersPanel")
                .classList.toggle("-translate-x-full");
        }

        var map = L.map('map').setView([4.6, -74.1], 6);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
            .addTo(map);
    </script>

</body>
</html>