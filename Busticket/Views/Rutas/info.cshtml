@using Busticket.Extensions
@model Busticket.Models.ReporteVentaVM

@{
    ViewBag.Title = "Selección de Asientos";
    Layout = null;
}


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Busticket</title>

    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="bg-gradient-to-br from-slate-100 via-zinc-100 to-slate-200 text-slate-800">

    <!-- HEADER -->
    <header class="absolute top-0 inset-x-0 z-50">
        <div class="max-w-7xl mx-auto px-10 py-6
                flex items-center justify-between
                text-black">

            <!-- IZQUIERDA -->
            <div class="flex items-center gap-6">

                <!-- BOTÓN VOLVER -->
                @if (Context.Request.Path != "/Home/Index")
                {
                    <button onclick="history.back()"
                            class="flex items-center gap-2 text-sm tracking-widest uppercase
                                   opacity-80 hover:opacity-100 transition group">

                        <!-- ICONO FLECHA SVG -->
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-5 h-5 transform group-hover:-translate-x-1 transition duration-300"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M15 19l-7-7 7-7" />
                        </svg>

                        Volver
                    </button>
                }

                <!-- LOGO -->
                <a href="/Home/Index"
                   class="text-2xl tracking-widest uppercase font-semibold">
                    Busticket
                </a>

            </div>

            <!-- DERECHA -->
            <div class="flex gap-10 text-sm tracking-widest uppercase items-center">

                <!-- AYUDA -->
                <a href="/Ayuda"
                   class="relative
                      after:content-[''] after:absolute after:left-0 after:-bottom-1
                      after:w-0 after:h-[1px] after:bg-black
                      after:transition-all after:duration-300
                      hover:after:w-full">
                    Ayuda
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <!-- PERFIL -->
                    <a href="/Perfil"
                       title="Mi cuenta"
                       class="flex items-center justify-center w-10 h-10
                              rounded-full border border-black
                              hover:bg-black hover:text-white transition">
                        👤
                    </a>

                    <!-- LOGOUT -->
                    <form asp-controller="Auth"
                          asp-action="Logout"
                          method="post"
                          class="inline">
                        <button type="submit"
                                class="relative
                                       after:content-[''] after:absolute after:left-0 after:-bottom-1
                                       after:w-0 after:h-[1px] after:bg-black
                                       after:transition-all after:duration-300
                                       hover:after:w-full">
                            Cerrar sesión
                        </button>
                    </form>
                }
                else
                {
                    <!-- LOGIN -->
                    <a href="/Auth/Login"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Iniciar sesión
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Admin
                    </a>
                }

                @if (User.IsInRole("Empresa"))
                {
                    <a href="/Empresa/Dashboard"
                       class="relative
                              after:content-[''] after:absolute after:left-0 after:-bottom-1
                              after:w-0 after:h-[1px] after:bg-black
                              after:transition-all after:duration-300
                              hover:after:w-full">
                        Empresa
                    </a>
                }

            </div>
            <div class="relative">
                <button id="btnCarrito">
                    <i class="fa fa-shopping-cart text-lg"></i>
                </button>

                <div id="dropdownCarrito"
                     class="hidden absolute right-0 mt-3 w-72 bg-white rounded-2xl p-5 shadow-xl z-50">

                    <h3 class="text-xs tracking-widest uppercase text-slate-500 mb-3">
                        Carrito
                    </h3>

                    @{
                        var carrito = Context.Session
                        .GetObjectFromJson<List<Busticket.Models.CarritoItem>>("Carrito")
                        ?? new List<Busticket.Models.CarritoItem>();
                    }

                    <ul id="listaCarrito" class="space-y-2 text-sm">
                        @if (!carrito.Any())
                        {
                            <li class="text-center text-slate-400 text-xs">
                                Carrito vacío
                            </li>
                        }
                        else
                        {
                            @foreach (var item in carrito)
                            {
                                <li class="flex justify-between border-b pb-1" data-id="@item.AsientoId">
                                    <span>Asiento @item.Codigo</span>
                                    <button class="text-red-500 text-xs" onclick="eliminarAsiento(@item.AsientoId)">❌</button>
                                </li>
                            }
                        }
                    </ul>

                    <p class="mt-4 text-right text-sm font-semibold">
                        Total:
                        <span id="totalCarrito">
                            @(carrito.Sum(a => a.Precio).ToString("N0"))
                        </span> COP
                    </p>

                    <a href="/Pago/Index"
                       class="block mt-4 text-center bg-slate-900 text-white py-2 rounded-full text-xs">
                        Finalizar compra
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-[1400px] mx-auto px-10 py-12 grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- MAPA ASIENTOS -->
        <section class="bg-white/70 backdrop-blur-xl rounded-3xl p-8 shadow-xl">

            <h2 class="text-sm tracking-widest uppercase text-slate-500 mb-6">
                Selección de asiento
            </h2>

            <!-- LEYENDA -->
            <div class="flex flex-wrap gap-6 mb-6 text-sm justify-center">
                <span class="flex items-center gap-2">
                    <span class="w-4 h-4 bg-blue-300 rounded"></span> Ventana 🪟
                </span>
                <span class="flex items-center gap-2">
                    <span class="w-4 h-4 bg-green-300 rounded"></span> Cerca al pasillo
                </span>
        
                <span class="flex items-center gap-2">
                    <span class="w-4 h-4 bg-yellow-300 rounded"></span> Reservado
                </span>
                <span class="flex items-center gap-2">
                    <span class="w-4 h-4 bg-red-300 rounded"></span> Ocupado
                </span>
            </div>

            @{
                var asientos = Model.Asientos.ToList();
                int columnas = 5;
            }

            <!-- FILAS SUPERIORES -->
            @for (int fila = 0; fila < 2; fila++)
            {
                <div class="grid grid-cols-5 gap-4 justify-center mb-2">
                    @for (int col = 0; col < columnas; col++)
                    {
                        int index = fila + (col * 4);
                        if (index < asientos.Count)
                        {
                            var asiento = asientos[index];

                            string clase = "";
                            bool disabled = false;

                            // ESTADO
                            if (!asiento.Disponible)
                            {
                                clase = "bg-red-300 text-red-800 cursor-not-allowed";
                                disabled = true;
                            }
                            else if (asiento.Reservado)
                            {
                                clase = "bg-yellow-300 text-yellow-800 cursor-not-allowed";
                                disabled = true;
                            }
                            else
                            {
                                clase = "bg-white border border-[#c9a24d] text-[#8a6b2e] hover:bg-[#c9a24d] hover:text-white";
                            }

                            // POSICIÓN
                            string posicion = "";
                            string icono = "";
                            string etiqueta = "";

                            if (fila == 0)
                            {
                                posicion = "Cerca a ventana";
                                icono = "🪟";
                                clase += " ring-2 ring-blue-400";
                            }
                            else if (fila == 1)
                            {
                                posicion = "Cerca al pasillo";
                                clase += " ring-2 ring-green-400";
                            }

                        

                            <button class="asiento w-12 h-12 rounded-md font-semibold relative @clase"
                                    title="@posicion"
                                    data-id="@asiento.AsientoId"
                                    data-codigo="@asiento.Numero"
                                    @(disabled ? "disabled" : "")>

                                @asiento.Numero

                                @if (!string.IsNullOrEmpty(icono))
                                {
                                    <span class="absolute -top-2 -right-2 text-xs">
                                        @icono
                                    </span>
                                }

                                @if (!string.IsNullOrEmpty(etiqueta))
                                {
                                    <span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[10px] text-orange-600 font-bold">
                                        @etiqueta
                                    </span>
                                }

                            </button>
                        }
                    }
                </div>
            }

            <!-- PASILLO -->
            <div class="text-center my-4 text-xs tracking-widest text-yellow-500 font-semibold">
                Entrada─────────────── PASILLO ─────────
            </div>

            <!-- FILAS INFERIORES -->
            @for (int fila = 2; fila < 4; fila++)
            {
                <div class="grid grid-cols-5 gap-4 justify-center mb-2">
                    @for (int col = 0; col < columnas; col++)
                    {
                        int index = fila + (col * 4);
                        if (index < asientos.Count)
                        {
                            var asiento = asientos[index];

                            string clase = "";
                            bool disabled = false;

                            if (!asiento.Disponible)
                            {
                                clase = "bg-red-300 text-red-800 cursor-not-allowed";
                                disabled = true;
                            }
                            else if (asiento.Reservado)
                            {
                                clase = "bg-yellow-300 text-yellow-800 cursor-not-allowed";
                                disabled = true;
                            }
                            else
                            {
                                clase = "bg-white border border-[#c9a24d] text-[#8a6b2e] hover:bg-[#c9a24d] hover:text-white";
                            }

                            string posicion = "";
                            string icono = "";
                            string etiqueta = "";

                            if (fila == 3)
                            {
                                posicion = "Cerca a ventana";
                                icono = "🪟";
                                clase += " ring-2 ring-blue-400";
                            }
                            else if (fila == 2)
                            {
                                posicion = "Cerca al pasillo";
                                clase += " ring-2 ring-green-400";
                            }

                         

                            <button class="asiento w-12 h-12 rounded-md font-semibold relative @clase"
                                    title="@posicion"
                                    data-id="@asiento.AsientoId"
                                    data-codigo="@asiento.Numero"
                                    @(disabled ? "disabled" : "")>

                                @asiento.Numero

                                @if (!string.IsNullOrEmpty(icono))
                                {
                                    <span class="absolute -top-2 -right-2 text-xs">
                                        @icono
                                    </span>
                                }

                                @if (!string.IsNullOrEmpty(etiqueta))
                                {
                                    <span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[10px] text-orange-600 font-bold">
                                        @etiqueta
                                    </span>
                                }

                            </button>
                        }
                    }
                </div>
            }

        </section>

        <!-- RESUMEN -->
        <section class="bg-white/70 backdrop-blur-xl rounded-3xl p-8 shadow-xl text-center">

            <img src="https://res.cloudinary.com/dbt58u6ag/image/upload/v1773173941/bus_nctjlv.webp"
                 class="w-40 mx-auto mb-4 opacity-80"
                 alt="Bus">

            <p class="text-lg font-semibold">
                Total: <span id="total">0</span> COP
            </p>

            <form>
                @Html.AntiForgeryToken()
            </form>

            <button id="agregarCarrito"
                    class="mt-6 w-full bg-slate-900 text-white py-3 rounded-full hover:bg-slate-700 transition">
                Agregar al carrito
            </button>

        </section>

    </main>

    <script>
        (() => {

            let asientosSeleccionados = [];
            const precio = parseInt("@Model.Ruta.Precio");
            const formato = new Intl.NumberFormat("es-CO");

            function actualizarTotal() {
                document.getElementById("total").textContent =
                    formato.format(asientosSeleccionados.length * precio);
            }

                    document.querySelectorAll(".asiento").forEach(btn => {
            btn.addEventListener("click", async () => {
                if (btn.disabled) return;

                const asientoId = parseInt(btn.dataset.id);
                const codigo = btn.dataset.codigo;

                const index = asientosSeleccionados.findIndex(a => a.AsientoId === asientoId);

                if (index >= 0) {
                    // Si ya está seleccionado, quitarlo (deseleccionar)
                    asientosSeleccionados.splice(index, 1);
                    btn.classList.remove("bg-slate-900", "text-white");
                    btn.classList.add("bg-white", "border", "border-[#c9a24d]", "text-[#8a6b2e]");
                    actualizarTotal();
                    return;
                }

                // Si no está seleccionado, reservarlo (como antes)
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                const res = await fetch("/Asientos/Reservar", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": token
                    },
                    body: JSON.stringify(asientoId)
                });

                if (!res.ok) {
                    Swal.fire("Ocupado", "Asiento no disponible", "warning");
                    btn.disabled = true;
                    btn.classList.add("bg-yellow-300");
                    return;
                }

                asientosSeleccionados.push({
                    AsientoId: asientoId,
                    Codigo: codigo,
                    Precio: precio,
                    RutaId: @Model.Ruta.RutaId
                });

                btn.classList.remove("bg-white", "border", "border-[#c9a24d]", "text-[#8a6b2e]");
                btn.classList.add("bg-slate-900", "text-white");

                actualizarTotal();
            });
        });

        document.getElementById("agregarCarrito").addEventListener("click", async () => {

            if (asientosSeleccionados.length === 0) {
                Swal.fire("Atención", "Selecciona al menos un asiento", "warning");
                return;
            }

            const token = document.querySelector(
                'input[name="__RequestVerificationToken"]'
            ).value;

            const res = await fetch("/Carrito/Agregar", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": token
                },
                body: JSON.stringify({
                    RutaId: @Model.Ruta.RutaId,
                    Asientos: asientosSeleccionados
                })
            });

            if (!res.ok) {
                Swal.fire("Error", "No se pudo agregar al carrito", "error");
                return;
            }

            const data = await res.json();

            // 🔥 TOAST PRO
            Swal.fire({
                toast: true,
                position: "top-end",
                icon: "success",
                title: "Asientos agregados 🛒",
                showConfirmButton: false,
                timer: 2000
            });

            // 🔥 ACTUALIZAR LISTA CARRITO
            const lista = document.getElementById("listaCarrito");

            if (lista.innerText.includes("Carrito vacío")) {
                lista.innerHTML = "";
            }

            asientosSeleccionados.forEach(a => {
                const li = document.createElement("li");
                li.className = "flex justify-between border-b pb-1";
                li.setAttribute("data-id", a.AsientoId);

                li.innerHTML = `
                    <span>Asiento ${a.Codigo}</span>
                    <button class="text-red-500 text-xs" onclick="eliminarAsiento(${a.AsientoId})">❌</button>
                `;

                lista.appendChild(li);
            });

            // 🔥 ACTUALIZAR TOTAL
            document.getElementById("totalCarrito").textContent =
                data.total.toLocaleString();

            // 🔥 LIMPIAR SELECCIÓN VISUAL
            asientosSeleccionados = [];
            document.getElementById("total").textContent = "0";

            document.querySelectorAll(".asiento.bg-slate-900").forEach(btn => {
                btn.classList.remove("bg-slate-900", "text-white");
                btn.classList.add("bg-white", "border", "border-[#c9a24d]", "text-[#8a6b2e]");
            });

        });

        })();
    </script>

    <script>
        const btnCarrito = document.getElementById("btnCarrito");
        const dropdown = document.getElementById("dropdownCarrito");

        btnCarrito.onclick = e => {
            e.stopPropagation();
            dropdown.classList.toggle("hidden");
        };

        document.addEventListener("click", () => dropdown.classList.add("hidden"));
    </script>

    <script>
             async function eliminarAsiento(asientoId) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const res = await fetch("/Carrito/Eliminar", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": token   
                },
                body: JSON.stringify({ asientoId })
            });

            if (!res.ok) {
                Swal.fire("Error", "No se pudo eliminar el asiento", "error");
                return;
            }

            const data = await res.json();

            // Actualizar total y cantidad en la vista
            document.getElementById("totalCarrito").textContent = data.total.toLocaleString();
            document.getElementById("listaCarrito").querySelector(`li[data-id='${asientoId}']`)?.remove();
        }
    </script>

</body>
</html>