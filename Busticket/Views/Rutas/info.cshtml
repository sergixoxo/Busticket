@using Busticket.Extensions
@model Busticket.Models.ReporteVentaVM

@{
    ViewBag.Title = "Busticket - Selección de Asientos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Busticket</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        .asiento:hover .tooltip {
            display: block;
        }
    </style>
</head>

<body class="bg-gradient-to-br from-slate-100 via-zinc-100 to-slate-200 text-slate-800">

    <header class="sticky top-0 z-50 bg-white/70 backdrop-blur-xl border-b border-white/40 shadow-sm">
        <div class="w-[95%] max-w-[1400px] mx-auto py-6 flex items-center justify-between">

            <a href="/Home/Index"
               class="text-sm tracking-[0.35em] uppercase font-light text-slate-900">
                Busticket
            </a>

            <div class="relative">
                <button id="btnCarrito">
                    <i class="fa fa-shopping-cart text-xl text-slate-700 hover:text-black transition"></i>
                </button>

                <div id="dropdownCarrito"
                     class="hidden absolute right-0 mt-3 w-72 bg-white/80 backdrop-blur-xl
                        shadow-xl rounded-2xl p-5 border border-white/40 z-50">

                    <h3 class="text-xs tracking-widest uppercase text-slate-500 mb-3">
                        Carrito
                    </h3>

                    <ul id="listaCarrito" class="space-y-1 text-sm">
                        @{
                            var carrito = Context.Session
                            .GetObjectFromJson<List<Busticket.DTOs.CarritoItem>>("Carrito")
                            ?? new();
                        }

                        @foreach (var item in carrito)
                        {
                            <li class="border-b pb-1">
                                Asiento @item.Codigo
                            </li>
                        }
                    </ul>

                    <p class="mt-4 font-semibold text-right">
                        Total:
                        <span id="totalCarrito">
                            @(carrito.Sum(a => a.Precio).ToString("N0"))
                        </span> COP
                    </p>

                    <a href="/Pago/Index"
                       class="block mt-4 text-center rounded-full
                          bg-gradient-to-r from-slate-900 to-slate-700
                          py-2 text-white text-xs tracking-widest uppercase">
                        Finalizar compra
                    </a>
                </div>
            </div>
        </div>
    </header>


    <main class="max-w-[1400px] mx-auto px-10 py-12 grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- MAPA ASIENTOS -->
        <section class="bg-white/70 backdrop-blur-xl rounded-3xl p-8 shadow-xl">

            <h2 class="text-sm tracking-widest uppercase text-slate-500 mb-6">
                Selección de asiento
            </h2>

            <div class="grid grid-cols-5 gap-3 justify-items-center">

                @foreach (var asiento in Model.Asientos)
                {
                    <button class="asiento w-10 h-10 rounded-md text-xs font-semibold border
            @(asiento.Disponible
                                        ? "bg-white border-[#c9a24d] text-[#8a6b2e]"
                                        : "bg-slate-300 text-slate-500 cursor-not-allowed")"
                            data-id="@asiento.AsientoId"
                            data-codigo="@asiento.Numero"
                            @(asiento.Disponible ? "" : "disabled")>

                        @asiento.Numero
                    </button>
                }

            </div>
        </section>

        <!-- RESUMEN -->
        <section class="bg-white/70 backdrop-blur-xl rounded-3xl p-8 shadow-xl">

            <p class="text-lg font-semibold">
                Total: <span id="total">0</span> COP
            </p>

            <form>
                @Html.AntiForgeryToken()
            </form>

            <button id="agregarCarrito"
                    class="mt-6 w-full rounded-full bg-slate-900 py-3 text-white">
                Agregar al carrito
            </button>

        </section>
    </main>

    <script>
        (() => {

            let asientosSeleccionados = [];
            const precioAsiento = parseInt("@Model.Ruta.Precio");
            const formato = new Intl.NumberFormat("es-CO");

            function actualizarTotal() {
                document.getElementById("total").textContent =
                    formato.format(asientosSeleccionados.length * precioAsiento);
            }

            document.querySelectorAll(".asiento").forEach(btn => {
                btn.addEventListener("click", () => {
                    if (btn.disabled) return;

                    const asientoId = parseInt(btn.dataset.id);
                    const codigo = btn.dataset.codigo;

                    const index = asientosSeleccionados.findIndex(a => a.AsientoId === asientoId);

                    if (index >= 0) {
                        asientosSeleccionados.splice(index, 1);
                        btn.classList.remove("bg-slate-900", "text-white");
                        btn.classList.add("bg-white", "text-[#8a6b2e]");
                    } else {
                        asientosSeleccionados.push({
                            AsientoId: asientoId,
                            Codigo: codigo,
                            Precio: precioAsiento,
                            RutaId: @Model.Ruta.RutaId
                        });

                        btn.classList.remove("bg-white", "text-[#8a6b2e]");
                        btn.classList.add("bg-slate-900", "text-white");
                    }

                    actualizarTotal();
                });
            });

            document.getElementById("agregarCarrito").addEventListener("click", async () => {

                if (asientosSeleccionados.length === 0) {
                    Swal.fire("Atención", "Selecciona al menos un asiento", "warning");
                    return;
                }

                const token = document.querySelector(
                    'input[name="__RequestVerificationToken"]'
                ).value;

                const res = await fetch("/Carrito/Agregar", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": token
                    },
                    body: JSON.stringify({
                        RutaId: @Model.Ruta.RutaId,
                        Asientos: asientosSeleccionados
                    })
                });

                const json = await res.json();

                if (!res.ok) {
                    Swal.fire("Error", json.mensaje, "error");
                    return;
                }

                Swal.fire("Listo", json.mensaje, "success");
                asientosSeleccionados = [];
                actualizarTotal();
            });

        })();
                const btnCarrito = document.getElementById("btnCarrito");
        const dropdownCarrito = document.getElementById("dropdownCarrito");

        btnCarrito.addEventListener("click", e => {
            e.stopPropagation();
            dropdownCarrito.classList.toggle("hidden");
        });

        document.addEventListener("click", () => {
            dropdownCarrito.classList.add("hidden");
        });

        dropdownCarrito.addEventListener("click", e => e.stopPropagation());

    </script>

</body>
</html>
