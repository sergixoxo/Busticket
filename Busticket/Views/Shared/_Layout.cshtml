<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Busticket</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-gray-50 text-gray-800">

    <!-- HEADER SIMPLE -->
    <header class="bg-white shadow-sm">
        <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex justify-between items-center">

            <a asp-controller="Home" asp-action="Index"
               class="text-2xl font-bold text-[#284D67]">
                Busticket
            </a>

            <nav class="hidden sm:flex gap-8 text-sm font-medium">
                <a asp-controller="Home" asp-action="Index"
                   class="hover:text-blue-600 transition">
                    Home
                </a>

                <a asp-controller="Home" asp-action="Privacy"
                   class="hover:text-blue-600 transition">
                    Privacy
                </a>
            </nav>

        </div>
    </header>

    <!-- CONTENIDO -->
    <main class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="border-t mt-16 py-6 text-center text-sm text-gray-500">
        &copy; 2025 - Busticket
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>